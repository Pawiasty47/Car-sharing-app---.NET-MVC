@model RegisterVM
@{
    ViewData["Title"] = "Rejestracja";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-success text-white">
                <h3 class="mb-0">
                    <i class="bi bi-person-plus-fill me-2"></i>Utwórz konto
                </h3>
            </div>

            <div class="card-body p-4">

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        <strong>Ups! Coś jest nie tak:</strong>
                        <div asp-validation-summary="All" class="mb-0"></div>
                    </div>
                }

                <form asp-action="Register" method="post">

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="FirstName" class="form-label fw-bold">Imię</label>
                            <input asp-for="FirstName" class="form-control" placeholder="np. Jan" />
                            <span asp-validation-for="FirstName" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="LastName" class="form-label fw-bold">Nazwisko</label>
                            <input asp-for="LastName" class="form-control" placeholder="np. Kowalski" />
                            <span asp-validation-for="LastName" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label fw-bold">Email</label>
                            <input asp-for="Email" class="form-control" placeholder="np. osoba@example.com" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label fw-bold">Numer telefonu</label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="np. 600123456" />
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Password" class="form-label fw-bold">Hasło</label>
                            <input asp-for="Password" class="form-control" type="password" placeholder="Min. 6 znaków" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ConfirmPassword" class="form-label fw-bold">Powtórz hasło</label>
                            <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Wpisz ponownie" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn btn-success btn-lg">
                            <i class="bi bi-check-circle-fill me-2"></i>Utwórz konto
                        </button>
                        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary">
                            Masz już konto? Zaloguj się
                        </a>
                    </div>

                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

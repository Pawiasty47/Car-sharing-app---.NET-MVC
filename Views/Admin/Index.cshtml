@model projekt_zespołowy.Controllers.AdminDashboardVM

@{
    ViewData["Title"] = "Dashboard Analityczny";
}

<div class="container mt-5">

    <div class="mb-4 border-bottom pb-3">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="fw-bold mb-0"><i class="bi bi-gear-fill me-2"></i>Panel Administratora</h2>
            <a asp-controller="Report" asp-action="Index" class="btn btn-danger shadow-sm fw-bold">
                <i class="bi bi-envelope-exclamation-fill me-2"></i>Zgłoszenia użytkowników
            </a>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-controller="Admin" asp-action="Users" class="btn btn-outline-primary shadow-sm fw-bold">
                <i class="bi bi-people-fill me-1"></i> Użytkownicy
            </a>
            <a asp-controller="Admin" asp-action="Index" class="btn btn-success shadow-sm fw-bold">
                <i class="bi bi-graph-up-arrow me-1"></i> Dashboard Analityczny (Aktywne)
            </a>
            <a asp-controller="AdminDriver" asp-action="Index" class="btn btn-outline-warning text-dark shadow-sm fw-bold">
                <i class="bi bi-card-checklist me-1"></i> Wnioski Kierowców
            </a>
        </div>
    </div>
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white py-3">
                    <h6 class="mb-0 fw-bold text-success"><i class="bi bi-pie-chart-fill me-2"></i>Struktura Użytkowników</h6>
                </div>
                <div class="card-body d-flex justify-content-center align-items-center">
                    <canvas id="usersChart" style="max-height: 250px;"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white py-3">
                    <h6 class="mb-0 fw-bold text-success"><i class="bi bi-bar-chart-fill me-2"></i>Ilość Przejazdów (Ostatnie 7 dni)</h6>
                </div>
                <div class="card-body">
                    <canvas id="ridesChart" style="max-height: 250px;"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white py-3">
                    <h6 class="mb-0 fw-bold text-success"><i class="bi bi-geo-alt-fill me-2"></i>TOP 5 Kierunków</h6>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr><th class="ps-3">#</th><th>Miasto Docelowe</th><th class="text-end pe-3">Przejazdy</th></tr>
                        </thead>
                        <tbody>
                            @if (!Model.TopCities.Any())
                            {
                                <tr><td colspan="3" class="text-center text-muted py-3">Brak danych</td></tr>
                            }
                            else
                            {
                                int i = 1; foreach (var c in Model.TopCities)
                                {
                                    <tr><td class="ps-3 fw-bold text-muted">@i</td><td>@c.CityName</td><td class="text-end pe-3 fw-bold text-success">@c.RideCount</td></tr>
                                    i++;
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white py-3">
                    <h6 class="mb-0 fw-bold text-success"><i class="bi bi-cash-stack me-2"></i>Zarobki TOP 5 Kierowców (ost. miesiąc)</h6>
                </div>
                <div class="card-body">
                    <canvas id="earningsChart" style="max-height: 250px;"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white py-3">
                    <h6 class="mb-0 fw-bold text-primary"><i class="bi bi-map-fill me-2"></i>Najpopularniejsze Trasy</h6>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr><th class="ps-3">#</th><th>Trasa</th><th class="text-end pe-3">Liczba</th></tr>
                        </thead>
                        <tbody>
                            @if (!Model.PopularRoutes.Any())
                            {
                                <tr><td colspan="3" class="text-center text-muted py-3">Brak danych</td></tr>
                            }
                            else
                            {
                                int i = 1; foreach (var r in Model.PopularRoutes)
                                {
                                    <tr><td class="ps-3 fw-bold text-muted">@i</td><td>@r.RouteName</td><td class="text-end pe-3 fw-bold text-primary">@r.RideCount</td></tr>
                                    i++;
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white py-3">
                    <h6 class="mb-0 fw-bold text-info text-dark"><i class="bi bi-calendar-week-fill me-2"></i>Najgorętsze Dni Tygodnia</h6>
                </div>
                <div class="card-body">
                    <canvas id="daysOfWeekChart" style="max-height: 250px;"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white py-3">
                    <h6 class="mb-0 fw-bold text-danger"><i class="bi bi-star-fill me-2"></i>TOP 5 Pasażerów</h6>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr><th class="ps-3">#</th><th>Pasażer</th><th class="text-end pe-3">Rezerwacje</th></tr>
                        </thead>
                        <tbody>
                            @if (!Model.TopPassengers.Any())
                            {
                                <tr><td colspan="3" class="text-center text-muted py-3">Brak danych</td></tr>
                            }
                            else
                            {
                                int i = 1; foreach (var p in Model.TopPassengers)
                                {
                                    <tr><td class="ps-3 fw-bold text-muted">@i</td><td>@p.FullName</td><td class="text-end pe-3 fw-bold text-danger">@p.RideCount</td></tr>
                                    i++;
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3">
                    <h6 class="mb-0 fw-bold text-success"><i class="bi bi-wallet2 me-2"></i>Historia zarobków wszystkich kierowców</h6>
                </div>
                <div class="card-body p-0" style="max-height: 300px; overflow-y: auto;">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-light" style="position: sticky; top: 0; z-index: 1;">
                            <tr>
                                <th class="ps-4">Imię i Nazwisko Kierowcy</th>
                                <th class="text-center">Przewiezieni Pasażerowie</th>
                                <th class="text-end pe-4">Suma Zarobków</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.AllDriversEarnings.Any())
                            {
                                <tr><td colspan="3" class="text-center text-muted py-4">Brak danych o zarobkach.</td></tr>
                            }
                            else
                            {
                                foreach (var d in Model.AllDriversEarnings)
                                {
                                    <tr>
                                        <td class="ps-4 fw-bold text-muted">@d.DriverName</td>
                                        <td class="text-center">@d.CompletedRides</td>
                                        <td class="text-end pe-4 fw-bold text-success">@d.TotalEarnings PLN</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        var ctxUsers = document.getElementById('usersChart').getContext('2d');
        new Chart(ctxUsers, {
            type: 'doughnut',
            data: {
                labels: ['Kierowcy', 'Pasażerowie'],
                datasets: [{ data: [@Model.TotalDrivers, @Model.TotalPassengers], backgroundColor: ['#198754', '#6c757d'], borderWidth: 0 }]
            },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } } }
        });

        var ctxRides = document.getElementById('ridesChart').getContext('2d');
        new Chart(ctxRides, {
            type: 'bar',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Last7DaysLabels)),
                datasets: [{ label: 'Liczba tras', data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Last7DaysData)), backgroundColor: '#198754', borderRadius: 4 }]
            },
            options: { responsive: true, maintainAspectRatio: false, scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }, plugins: { legend: { display: false } } }
        });

        var ctxEarnings = document.getElementById('earningsChart').getContext('2d');
        new Chart(ctxEarnings, {
            type: 'bar',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DriverEarningsLabels)),
                datasets: [{ label: 'Zarobki (PLN)', data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DriverEarningsData)), backgroundColor: '#ffc107', borderRadius: 4 }]
            },
            options: { indexAxis: 'y', responsive: true, maintainAspectRatio: false, scales: { x: { beginAtZero: true } }, plugins: { legend: { display: false } } }
        });

        var ctxDays = document.getElementById('daysOfWeekChart').getContext('2d');
        new Chart(ctxDays, {
            type: 'bar',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DaysOfWeekLabels)),
                datasets: [{ label: 'Liczba Przejazdów', data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DaysOfWeekData)), backgroundColor: '#0dcaf0', borderRadius: 4 }]
            },
            options: { responsive: true, maintainAspectRatio: false, scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }, plugins: { legend: { display: false } } }
        });
    </script>
}
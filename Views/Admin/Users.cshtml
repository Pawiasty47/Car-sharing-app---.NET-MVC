@model List<projekt_zespołowy.Controllers.AdminUserListVM>

@{
    ViewData["Title"] = "Panel Administratora";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="container mt-5">

    <div class="mb-4 border-bottom pb-3">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="fw-bold mb-0"><i class="bi bi-gear-fill me-2"></i>Panel Administratora</h2>
            <a asp-controller="Report" asp-action="Index" class="btn btn-danger shadow-sm fw-bold">
                <i class="bi bi-envelope-exclamation-fill me-2"></i>Zgłoszenia użytkowników
            </a>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-controller="Admin" asp-action="Users" class="btn btn-primary shadow-sm fw-bold">
                <i class="bi bi-people-fill me-1"></i> Użytkownicy (Aktywne)
            </a>
            <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-success shadow-sm fw-bold">
                <i class="bi bi-graph-up-arrow me-1"></i> Dashboard Analityczny
            </a>
            <a asp-controller="AdminDriver" asp-action="Index" class="btn btn-outline-warning text-dark shadow-sm fw-bold">
                <i class="bi bi-card-checklist me-1"></i> Wnioski Kierowców
            </a>
        </div>
    </div>
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold text-primary">
                <i class="bi bi-list-ul me-2"></i>Lista użytkowników w systemie
            </h5>

            <form method="get" asp-action="Users" class="d-flex" style="max-width:350px;">
                <input type="text"
                       name="search"
                       value="@Context.Request.Query["search"]"
                       class="form-control me-2"
                       placeholder="Szukaj imię, nazwisko lub email...">

                <button type="submit" class="btn btn-outline-primary">
                    <i class="bi bi-search"></i>
                </button>
            </form>
        </div>
        <div class="card-body p-0">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Imię i Nazwisko</th>
                        <th>Email</th>
                        <th class="text-center">Kierowca?</th>
                        <th class="text-end">Opcje</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="align-middle">
                                <strong>@user.FullName</strong>
                            </td>
                            <td class="align-middle">
                                @user.Email
                            </td>
                            <td class="text-center align-middle">
                                @if (user.IsDriver)
                                {
                                    <span class="badge bg-success">TAK</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary" style="opacity: 0.5">NIE</span>
                                }
                            </td>
                            <td class="text-end">
                                <form asp-action="Delete" asp-route-id="@user.Id" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                            onclick="return confirm('Czy na pewno chcesz usunąć użytkownika @user.FullName?');">
                                        <i class="bi bi-trash"></i> Usuń
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
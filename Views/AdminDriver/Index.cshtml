@model IEnumerable<projekt_zespołowy.Models.DriverApplication>

@{
    ViewData["Title"] = "Panel Administratora - Wnioski";
}

<div class="container mt-5">

    <div class="mb-4 border-bottom pb-3">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="fw-bold mb-0"><i class="bi bi-gear-fill me-2"></i>Panel Administratora</h2>
            <a asp-controller="Report" asp-action="Index" class="btn btn-danger shadow-sm fw-bold">
                <i class="bi bi-envelope-exclamation-fill me-2"></i>Zgłoszenia użytkowników
            </a>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-controller="Admin" asp-action="Users" class="btn btn-outline-primary shadow-sm fw-bold">
                <i class="bi bi-people-fill me-1"></i> Użytkownicy
            </a>
            <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-success shadow-sm fw-bold">
                <i class="bi bi-graph-up-arrow me-1"></i> Dashboard Analityczny
            </a>
            <a asp-controller="AdminDriver" asp-action="Index" class="btn btn-warning text-dark shadow-sm fw-bold">
                <i class="bi bi-card-checklist me-1"></i> Wnioski Kierowców (Aktywne)
            </a>
        </div>
    </div>
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0 fw-bold text-warning text-dark">
                <i class="bi bi-hourglass-split me-2"></i>Oczekujące wnioski o status kierowcy
            </h5>
        </div>
        <div class="card-body p-0">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Użytkownik</th>
                        <th>PESEL / Wiek</th>
                        <th>Prawo Jazdy</th>
                        <th>Auto</th>
                        <th>Akcja</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="align-middle">
                                <strong>@item.User.FirstName @item.User.LastName</strong> <br />
                                <small class="text-muted">@item.User.Email</small>
                            </td>
                            <td class="align-middle">
                                @item.PESEL <br />
                                <small class="text-muted">(@item.DateOfBirth.ToShortDateString())</small>
                            </td>
                            <td class="align-middle">@item.DriverLicenseNumber (@item.LicenseCategories)</td>
                            <td class="align-middle">@item.Vehicle.Make @item.Vehicle.Model</td>
                            <td class="align-middle">
                                <form asp-action="Approve" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button class="btn btn-success btn-sm fw-bold">Akceptuj</button>
                                </form>

                                <button class="btn btn-danger btn-sm fw-bold" onclick="rejectApp('@item.Id')">Odrzuć</button>

                                <form id="rejectForm-@item.Id" asp-action="Reject" method="post" style="display:none;">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="hidden" name="reason" id="reason-@item.Id" />
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">Brak oczekujących wniosków.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

<script>
    function rejectApp(id) {
        let reason = prompt("Podaj powód odrzucenia:");
        if (reason) {
            document.getElementById('reason-' + id).value = reason;
            document.getElementById('rejectForm-' + id).submit();
        }
    }
</script>
@model IEnumerable<projekt_zespołowy.Models.Booking>

@{
    ViewData["Title"] = "Moje rezerwacje";
}

<div class="container mt-4">
    <h2>Moje rezerwacje</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            Nie masz jeszcze żadnych rezerwacji.
            <a asp-controller="Rides" asp-action="Index" class="alert-link">Znajdź przejazd</a>.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Trasa</th>
                        <th>Data wyjazdu</th>
                        <th>Kierowca</th>
                        <th>Status rezerwacji</th>
                        <th>Akcja</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @* Dostęp do danych przejazdu poprzez nawigację .Ride *@
                                <strong>@item.Ride.StartLocation.City</strong>
                                <i class="bi bi-arrow-right mx-1"></i>
                                <strong>@item.Ride.EndLocation.City</strong>
                            </td>
                            <td>
                                @item.Ride.DepartureTime.ToString("dd.MM.yyyy HH:mm")
                            </td>
                            <td>
                                @item.Ride.Driver.User.FirstName @item.Ride.Driver.User.LastName
                            </td>
                            <td>
                                @if (item.Status == projekt_zespołowy.Models.BookingStatus.Confirmed)
                                {
                                    <span class="badge bg-success">Zatwierdzona</span>
                                }
                                else if (item.Status == projekt_zespołowy.Models.BookingStatus.Pending)
                                {
                                    <span class="badge bg-warning text-dark">Oczekująca</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@item.Status</span>
                                }
                            </td>
                            <td>
                                @* Ten przycisk przeniesie Cię do widoku Summary, gdzie można ocenić kierowcę *@
                                <a asp-controller="Rides"
                                   asp-action="Summary"
                                   asp-route-id="@item.RideId"
                                   class="btn btn-primary btn-sm">
                                    Szczegóły / Oceń
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
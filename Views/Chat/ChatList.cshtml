@model List<Chat>

@{
    ViewData["Title"] = "Twoje czaty";
    var currentFilter = Context.Request.Query["filter"].ToString();
}

<div class="row justify-content-center">
    <div class="col-lg-10">

        <div class="card shadow-sm border-0">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h3 class="mb-0">
                    <i class="bi bi-chat-dots me-2"></i>Twoje czaty
                </h3>

                <!-- 🔍 FILTRY -->
                <div class="btn-group btn-group-sm">
                    <a asp-action="ChatList" asp-route-filter="all"
                       class="btn @(currentFilter == "driver" || currentFilter == "passenger" ? "btn-outline-light" : "btn-light")">
                        Wszystkie
                    </a>
                    <a asp-action="ChatList" asp-route-filter="driver"
                       class="btn @(currentFilter == "driver" ? "btn-light" : "btn-outline-light")">
                        Kierowca
                    </a>
                    <a asp-action="ChatList" asp-route-filter="passenger"
                       class="btn @(currentFilter == "passenger" ? "btn-light" : "btn-outline-light")">
                        Pasażer
                    </a>
                </div>
            </div>

            <div class="card-body p-4">

                @if (!Model.Any())
                {
                    <div class="alert alert-light text-center py-5">
                        <i class="bi bi-chat-dots fs-1 d-block mb-3"></i>
                        Brak dostępnych czatów.
                    </div>
                }
                else
                {
                    <div class="row g-3">
                        @foreach (var chat in Model)
                        {
                            var userId = Guid.Parse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier).Value);
                            var isDriver = chat.Ride?.Driver?.UserId == userId;

                            <div class="col-md-6 col-lg-4">
                                <div class="card shadow-sm border-0 h-100">
                                    <div class="card-body d-flex flex-column justify-content-between">

                                        <div>
                                            <h5 class="card-title mb-2 text-primary">
                                                @if (chat.Ride?.StartLocation != null && chat.Ride?.EndLocation != null)
                                                {
                                                    <i class="bi bi-geo-alt-fill me-1 text-success"></i>
                                                    @chat.Ride.StartLocation.City
                                                    <i class="bi bi-arrow-right mx-1"></i>
                                                    @chat.Ride.EndLocation.City
                                                }
                                                else
                                                {
                                                    <text>Przejazd</text>
                                                }
                                            </h5>

                                            <p class="text-muted mb-1 small">
                                                <i class="bi bi-person me-1"></i>
                                                Kierowca:
                                                @chat.Ride?.Driver?.User?.FirstName
                                                @chat.Ride?.Driver?.User?.LastName
                                            </p>

                                            <p class="text-muted mb-1 small">
                                                <i class="bi bi-clock me-1"></i>
                                                @(chat.Messages.Any()
                                                    ? chat.Messages.Max(m => m.CreatedAt).ToLocalTime().ToString("dd.MM HH:mm")
                                                    : "Brak wiadomości")
                                            </p>

                                            <p class="text-muted mb-0 small">
                                                <i class="bi bi-chat-left-text me-1"></i>
                                                @(chat.Messages?.Count ?? 0) wiadomości
                                            </p>

                                            <!-- 🔹 ROLA -->
                                            <span class="badge mt-2 @(isDriver ? "bg-success" : "bg-secondary")">
                                                @(isDriver ? "Kierowca" : "Pasażer")
                                            </span>
                                        </div>

                                        <div class="mt-3 text-end">
                                            <a asp-action="RideChat"
                                               asp-controller="Chat"
                                               asp-route-rideId="@chat.RideId"
                                               class="btn btn-primary btn-sm">
                                                <i class="bi bi-box-arrow-in-right me-1"></i>
                                                Otwórz
                                            </a>
                                        </div>

                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }

            </div>
        </div>

    </div>
</div>
@model Chat
@{
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
}

<div class="container mt-4">

    <!-- HEADER -->
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <h5 class="mb-0 fw-bold">
                    <i class="bi bi-chat-dots me-2 text-primary"></i>
                    Czat przejazdu
                </h5>

                <small class="text-muted">
                    @if (Model.Ride != null && Model.Ride.StartLocation != null && Model.Ride.EndLocation != null)
                    {
                        @Model.Ride.StartLocation.City <text>→</text> @Model.Ride.EndLocation.City
                    }
                    else
                    {
                        <text>Przejazd</text>
                    }
                </small>
            </div>

            <a asp-controller="Rides"
               asp-action="Details"
               asp-route-id="@Model.RideId"
               class="btn btn-sm btn-outline-secondary">
                Powrót
            </a>
        </div>
    </div>

    <!-- MESSAGES -->
    <div class="card border-0 shadow-sm">
        <div class="card-body p-3"
             style="height: 450px; overflow-y: auto; background-color: #f8f9fa;">

            @if (Model.Messages != null && Model.Messages.Any())
            {
                @foreach (var msg in Model.Messages.OrderBy(m => m.CreatedAt))
                {
                    var isMe = msg.SenderId.ToString() == currentUserId;

                    <div class="d-flex mb-3 @(isMe ? "justify-content-end" : "justify-content-start")">

                        <div class="p-2 px-3 rounded shadow-sm"
                             style="max-width: 70%;
                                    background-color: @(isMe ? "#0d6efd" : "#ffffff");
                                    color: @(isMe ? "white" : "black");">

                            @if (!isMe)
                            {
                                <div class="fw-bold small mb-1 text-primary">
                                    @(msg.Sender != null ? msg.Sender.FirstName : "Użytkownik")
                                </div>
                            }

                            <div>
                                @msg.Content
                            </div>

                            <div class="text-end small mt-1" style="opacity: 0.7;">
                                @msg.CreatedAt.ToString("HH:mm")
                            </div>
                        </div>

                    </div>
                }
            }
            else
            {
                <div class="text-center text-muted mt-5">
                    <i class="bi bi-chat-dots fs-1 d-block mb-2"></i>
                    Brak wiadomości
                </div>
            }

        </div>

        <!-- INPUT -->
        <div class="card-footer bg-white border-0">
            <form asp-action="SendMessage" method="post">
                <input type="hidden" name="chatId" value="@Model.Id" />

                <div class="input-group">
                    <input name="content"
                           class="form-control"
                           placeholder="Napisz wiadomość..."
                           autocomplete="off" />

                    <button class="btn btn-primary">
                        Wyślij
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
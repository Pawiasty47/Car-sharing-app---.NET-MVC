@model projekt_zespołowy.Models.ViewModels.DriverApplicationViewModel

<h2>Zostań Kierowcą</h2>
<hr />

<form asp-action="Apply" method="post">
    <h4 class="mb-3 text-muted">Dane Tożsamości</h4>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label asp-for="FirstName" class="form-label"></label>
            <input asp-for="FirstName" class="form-control" placeholder="np. Anna" />
            <span asp-validation-for="FirstName" class="text-danger"></span>
        </div>

        <div class="col-md-4 mb-3">
            <label asp-for="SecondName" class="form-label"></label>
            <input asp-for="SecondName" class="form-control" placeholder="np. Maria" />
            <span asp-validation-for="SecondName" class="text-danger"></span>
        </div>

        <div class="col-md-4 mb-3">
            <label asp-for="LastName" class="form-label"></label>
            <input asp-for="LastName" class="form-control" placeholder="np. Nowak" />
            <span asp-validation-for="LastName" class="text-danger"></span>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="IdDocumentNumber" class="form-label"></label>
        <input asp-for="IdDocumentNumber" class="form-control" placeholder="np. ABC 123456" />
        <span asp-validation-for="IdDocumentNumber" class="text-danger"></span>
    </div>

    <hr class="my-4" />
    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="DriverLicenseNumber" class="form-label"></label>
            <input asp-for="DriverLicenseNumber" class="form-control" />
            <span asp-validation-for="DriverLicenseNumber" class="text-danger"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="LicenseCategories" class="form-label"></label>
            <input asp-for="LicenseCategories" class="form-control" placeholder="np. B" />
            <span asp-validation-for="LicenseCategories" class="text-danger"></span>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="DateOfBirth" class="form-label">Data urodzenia</label>

            <input asp-for="DateOfBirth" type="date" class="form-control"
                   max="@DateTime.Now.AddYears(-18).ToString("yyyy-MM-dd")" />

            <span asp-validation-for="DateOfBirth" class="text-danger"></span>
            <small class="text-muted">Musisz mieć ukończone 18 lat.</small>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="PESEL" class="form-label"></label>
            <input asp-for="PESEL" class="form-control" />
            <span asp-validation-for="PESEL" class="text-danger"></span>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="SelectedVehicleId" class="form-label fw-bold">Wybierz samochód do weryfikacji</label>

        <select asp-for="SelectedVehicleId" asp-items="Model.MyVehicles" class="form-select">
            <option value="">-- Kliknij, aby wybrać swój pojazd --</option>
        </select>

        <span asp-validation-for="SelectedVehicleId" class="text-danger"></span>
        <div class="form-text">
            Na liście widoczne są tylko te pojazdy, które dodałaś wcześniej w zakładce "Moje Pojazdy".
        </div>
        <div class="mt-2">
            <a asp-controller="Vehicle" asp-action="Create" asp-route-returnUrl="@Url.Action("Index","DriverApplication")" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-plus-circle me-1"></i>Dodaj pojazd
            </a>
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Wyślij wniosek</button>
</form>
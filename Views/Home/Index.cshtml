@model HomeIndexViewModel
@{
    ViewData["Title"] = "Strona główna";
}

@if (Model.IsLoggedIn && Model.UnreadNotifications != null && Model.UnreadNotifications.Any())
{
    <div class="container mt-4">
        <div class="row justify-content-center">
            <div class="col-md-10">
                @foreach (var notif in Model.UnreadNotifications)
                {
                    <div class="alert alert-danger shadow border-danger border-2 mb-3" role="alert">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h4 class="alert-heading fw-bold"><i class="bi bi-exclamation-octagon-fill me-2"></i>@notif.Title</h4>
                                <p class="mb-1 fs-5">@notif.Body</p>
                                <small class="text-muted">Wysłano: @notif.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</small>
                            </div>
                            <form asp-controller="Home" asp-action="MarkNotificationAsRead" method="post">
                                <input type="hidden" name="id" value="@notif.Id" />
                                <button type="submit" class="btn btn-sm btn-danger fw-bold shadow-sm">
                                    Zrozumiałem, ukryj
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

<div class="container mt-4 mb-5">
    <div class="row align-items-center bg-success text-white rounded-4 shadow-sm p-5">
        <div class="col-md-7">
            <h1 class="display-4 fw-bold mb-3">Wóz albo Przewóz</h1>
            <p class="lead mb-4">
                Wspólne przejazdy • niższe koszty • mniej spalin.<br />
                Znajdź idealny przejazd lub zaoferuj wolne miejsca w swoim aucie!
            </p>
            <div class="d-flex gap-3">
                <a asp-controller="Rides" asp-action="Index" class="btn btn-light btn-lg text-success fw-bold px-4 shadow-sm">
                    <i class="bi bi-search me-2"></i> Szukaj przejazdu
                </a>
                <a asp-controller="Rides" asp-action="Create" class="btn btn-outline-light btn-lg px-4">
                    <i class="bi bi-plus-circle me-2"></i> Dodaj trasę
                </a>
            </div>
        </div>
        <div class="col-md-5 text-center d-none d-md-block">
            <i class="bi bi-car-front-fill opacity-75" style="font-size: 12rem;"></i>
        </div>
    </div>
</div>

<div class="container mb-5 py-4">
    <div class="text-center mb-5">
        <h2 class="fw-bold text-success">Jak to działa?</h2>
        <p class="text-muted">Trzy proste kroki do udanej podróży</p>
    </div>

    <div class="row g-4 text-center">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm rounded-4 p-4 hover-effect">
                <div class="card-body">
                    <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                        <i class="bi bi-geo-alt-fill text-success" style="font-size: 2.5rem;"></i>
                    </div>
                    <h4 class="fw-bold mb-3">1. Znajdź przejazd</h4>
                    <p class="text-muted mb-0">Wpisz skąd i dokąd chcesz jechać, a nasz system pokaże Ci listę dostępnych tras.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm rounded-4 p-4 hover-effect">
                <div class="card-body">
                    <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                        <i class="bi bi-ticket-perforated-fill text-success" style="font-size: 2.5rem;"></i>
                    </div>
                    <h4 class="fw-bold mb-3">2. Zarezerwuj miejsce</h4>
                    <p class="text-muted mb-0">Sprawdź profil kierowcy i jednym kliknięciem zarezerwuj swoje miejsce w aucie.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm rounded-4 p-4 hover-effect">
                <div class="card-body">
                    <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                        <i class="bi bi-emoji-smile-fill text-success" style="font-size: 2.5rem;"></i>
                    </div>
                    <h4 class="fw-bold mb-3">3. Podróżuj taniej</h4>
                    <p class="text-muted mb-0">Oszczędzaj na paliwie i poznawaj ciekawych ludzi po drodze!</p>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="bg-light py-5 mb-5 rounded-4 shadow-sm container">
    <div class="text-center mb-5">
        <h2 class="fw-bold text-secondary">Opinie naszych użytkowników</h2>
        <p class="text-muted">Zobacz, co mówią o nas inni</p>

        @if (Model.IsLoggedIn)
        {
            <button type="button" class="btn btn-outline-success mt-2" data-bs-toggle="modal" data-bs-target="#addOpinionModal">
                <i class="bi bi-pencil-square me-2"></i> Dodaj własną opinię
            </button>
        }
    </div>

    <div class="row g-4 px-3">
        @if (Model.RecentOpinions != null && Model.RecentOpinions.Any())
        {
            @foreach (var opinion in Model.RecentOpinions)
            {
                <div class="col-md-4">
                    <div class="bg-white p-4 rounded-4 shadow-sm h-100 border-start border-success border-4 d-flex flex-column">
                        <div class="d-flex text-warning mb-2">
                            @for (int i = 0; i < opinion.Rating; i++)
                            {
                                <i class="bi bi-star-fill"></i>
                            }
                            @for (int i = opinion.Rating; i < 5; i++)
                            {
                                <i class="bi bi-star"></i>
                            }
                        </div>
                        <p class="fst-italic text-muted mb-4 flex-grow-1">"@opinion.Content"</p>
                        <div class="d-flex align-items-center mt-auto">
                            <div class="bg-success rounded-circle text-white d-flex align-items-center justify-content-center fw-bold me-3" style="width: 40px; height: 40px;">
                                @(opinion.User.FirstName?.Substring(0, 1) ?? opinion.User.UserName?.Substring(0, 1).ToUpper())
                            </div>
                            <div>
                                <h6 class="mb-0 fw-bold text-dark">@(opinion.User.FirstName ?? "Użytkownik")</h6>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-md-4">
                <div class="bg-white p-4 rounded-4 shadow-sm h-100 border-start border-success border-4 d-flex flex-column">
                    <div class="d-flex text-warning mb-2">
                        <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i>
                    </div>
                    <p class="fst-italic text-muted mb-4 flex-grow-1">"Świetni kierowcy i super atmosfera. Dzięki aplikacji oszczędzam mnóstwo czasu i pieniędzy na dojazdach."</p>
                    <div class="d-flex align-items-center mt-auto">
                        <div class="bg-secondary rounded-circle text-white d-flex align-items-center justify-content-center fw-bold me-3" style="width: 40px; height: 40px;">T</div>
                        <div>
                            <h6 class="mb-0 fw-bold text-dark">Tomek</h6>
                            <small class="text-muted">Pasażer</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="bg-white p-4 rounded-4 shadow-sm h-100 border-start border-success border-4 d-flex flex-column">
                    <div class="d-flex text-warning mb-2">
                        <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i>
                    </div>
                    <p class="fst-italic text-muted mb-4 flex-grow-1">"Codziennie dojeżdżam do pracy. Wóz albo Przewóz to najlepsza alternatywa dla pociągów!"</p>
                    <div class="d-flex align-items-center mt-auto">
                        <div class="bg-success rounded-circle text-white d-flex align-items-center justify-content-center fw-bold me-3" style="width: 40px; height: 40px;">A</div>
                        <div>
                            <h6 class="mb-0 fw-bold text-dark">Anna</h6>
                            <small class="text-muted">Kierowca</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="bg-white p-4 rounded-4 shadow-sm h-100 border-start border-success border-4 d-flex flex-column">
                    <div class="d-flex text-warning mb-2">
                        <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-half"></i>
                    </div>
                    <p class="fst-italic text-muted mb-4 flex-grow-1">"Bardzo intuicyjny interfejs i bezpieczne przejazdy. Podoba mi się, że widzę opinie przed podróżą."</p>
                    <div class="d-flex align-items-center mt-auto">
                        <div class="bg-primary rounded-circle text-white d-flex align-items-center justify-content-center fw-bold me-3" style="width: 40px; height: 40px;">M</div>
                        <div>
                            <h6 class="mb-0 fw-bold text-dark">Michał</h6>
                            <small class="text-muted">Pasażer</small>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (Model.TotalOpinions > 3)
    {
        <div class="text-center mt-5">
            <a asp-controller="Home" asp-action="AllOpinions" class="btn btn-link text-success text-decoration-none fw-bold fs-5">
                Zobacz wszystkie opinie <i class="bi bi-arrow-right"></i>
            </a>
        </div>
    }
</div>

<section class="container my-5">
    <div class="row text-center g-4">
        <div class="col-md-6">
            <div class="bg-white p-4 p-md-5 rounded-4 shadow-sm h-100 border-bottom border-success border-4 hover-effect">
                <i class="bi bi-people-fill text-success mb-3" style="font-size: 3rem;"></i>
                <h2 class="display-5 text-dark fw-bold mb-0">@Model.UsersCount</h2>
                <p class="text-muted fs-5 mt-2 mb-0">Zarejestrowanych użytkowników</p>
            </div>
        </div>
        <div class="col-md-6">
            <div class="bg-white p-4 p-md-5 rounded-4 shadow-sm h-100 border-bottom border-success border-4 hover-effect">
                <i class="bi bi-signpost-split-fill text-success mb-3" style="font-size: 3rem;"></i>
                <h2 class="display-5 text-dark fw-bold mb-0">@Model.RidesCount</h2>
                <p class="text-muted fs-5 mt-2 mb-0">Przejazdów w historii</p>
            </div>
        </div>
    </div>
</section>

<div class="container my-4">
    @if (Model.IsAdmin)
    {
        <div class="alert alert-warning text-center rounded-4 shadow-sm border-0 py-3">
            <i class="bi bi-shield-lock-fill me-2 fs-5"></i> 👑 Zalogowany jako <strong>Administrator</strong> —
            <a asp-controller="Admin" asp-action="Users" class="alert-link text-decoration-none">Przejdź do panelu admina <i class="bi bi-arrow-right"></i></a>
        </div>
    }

    @if (Model.IsDriver && !Model.IsAdmin)
    {
        <div class="alert alert-success text-center rounded-4 shadow-sm border-0 py-3">
            <i class="bi bi-car-front-fill me-2 fs-5"></i> 🚗 Jesteś <strong>kierowcą</strong> — możesz dodawać i edytować swoje przejazdy.
        </div>
    }

    @if (!User.IsInRole("Driver") && !User.IsInRole("Admin"))
    {
        <div class="alert alert-info text-center rounded-4 shadow-sm border-0 py-3 bg-opacity-10 text-primary">
            <i class="bi bi-info-circle-fill me-2 fs-5"></i> 🚗 Chcesz więcej możliwości? —
            <a asp-controller="DriverApplication" asp-action="Index" class="alert-link text-decoration-none fw-bold">Zostań kierowcą!</a>
        </div>
    }
</div>

<section class="container my-5 text-center">
    <h3 class="mb-4 text-secondary fw-bold">Nasi partnerzy</h3>

    <div class="bg-white p-4 rounded-4 shadow-sm">
        <div id="sponsorsCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="4000">
            <div class="carousel-inner">
                <div class="carousel-item active">
                    <img src="https://zakupersi.com/wp-content/uploads/2015/12/lech.png"
                         class="img-fluid sponsor-img"
                         alt="Sponsor 1">
                </div>
                <div class="carousel-item">
                    <img src="https://tyskie.pl/assets/img/tyskie-og.png"
                         class="img-fluid sponsor-img"
                         alt="Sponsor 2">
                </div>
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#sponsorsCarousel" data-bs-slide="prev">
                <i class="bi bi-chevron-left text-dark fs-2"></i>
                <span class="visually-hidden">Poprzedni</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#sponsorsCarousel" data-bs-slide="next">
                <i class="bi bi-chevron-right text-dark fs-2"></i>
                <span class="visually-hidden">Następny</span>
            </button>
        </div>
    </div>
</section>
<section class="container my-5 mb-5 pb-5">
    <div class="text-center mb-4">
        <h2 class="text-success fw-bold">Najczęściej zadawane pytania</h2>
        <p class="text-muted">Masz wątpliwości? Sprawdź nasze FAQ.</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="bg-white p-2 p-md-4 rounded-4 shadow-sm">
                <div class="accordion accordion-flush" id="faqAccordion">
                    <div class="accordion-item mb-3 rounded-3 border">
                        <h2 class="accordion-header">
                            <button class="accordion-button fw-bold rounded-3" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                                <i class="bi bi-question-circle text-success me-2 fs-5"></i> Czy korzystanie z serwisu jest darmowe?
                            </button>
                        </h2>
                        <div id="faq1" class="accordion-collapse collapse show" data-bs-parent="#faqAccordion">
                            <div class="accordion-body text-muted pt-0">
                                Tak - rejestracja, utrzymanie konta i przeglądanie przejazdów są całkowicie bezpłatne. Płacisz jedynie kierowcy za wspólną podróż zgodnie z jego cennikiem.
                            </div>
                        </div>
                    </div>

                    <div class="accordion-item mb-3 rounded-3 border">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed fw-bold rounded-3" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                                <i class="bi bi-steering text-success me-2 fs-5"></i> Jak mogę zostać kierowcą?
                            </button>
                        </h2>
                        <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body text-muted pt-0">
                                Wystarczy założyć konto, przejść do swojego profilu, kliknąć "Zostań kierowcą" i wypełnić krótki formularz weryfikacyjny dotyczący Twojego pojazdu.
                            </div>
                        </div>
                    </div>

                    <div class="accordion-item rounded-3 border">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed fw-bold rounded-3" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">
                                <i class="bi bi-search text-success me-2 fs-5"></i> Jak mogę wybrać przejazd?
                            </button>
                        </h2>
                        <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body text-muted pt-0">
                                Naciśnij przycisk "Szukaj przejazdu" na stronie głównej. Wpisz miasto początkowe i docelowe, a następnie wybierz z listy ofertę, która najbardziej Ci odpowiada.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="modal fade" id="addOpinionModal" tabindex="-1" aria-labelledby="addOpinionModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title fw-bold" id="addOpinionModalLabel">Dodaj opinię</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-controller="Home" asp-action="AddOpinion" method="post">
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Twoja ocena (1-5 gwiazdek)</label>
                        <select name="rating" class="form-select text-warning fw-bold">
                            <option value="5">⭐⭐⭐⭐⭐ (Super!)</option>
                            <option value="4">⭐⭐⭐⭐ (Bardzo dobrze)</option>
                            <option value="3">⭐⭐⭐ (Średnio)</option>
                            <option value="2">⭐⭐ (Słabo)</option>
                            <option value="1">⭐ (Tragedia)</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Napisz kilka słów</label>
                        <textarea name="content" class="form-control" rows="4" placeholder="Opisz swoje wrażenia..." required maxlength="500"></textarea>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Anuluj</button>
                    <button type="submit" class="btn btn-success fw-bold">Zapisz opinię</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    /* Nowe efekty */
    .hover-effect {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .hover-effect:hover {
            transform: translateY(-5px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
        }

    .sponsor-img {
        max-width: 100%;
        height: auto;
        max-height: 120px; 
        object-fit: contain;
        margin: 0 auto;
        display: block;
    }

    #sponsorsCarousel .carousel-control-prev-icon,
    #sponsorsCarousel .carousel-control-next-icon {
        display: none;
    }

    .accordion-button:not(.collapsed) {
        background-color: #e9f7ef;
        color: #198754;
        box-shadow: none; 
    }

    .accordion-button:focus {
        border-color: #198754;
        box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.25);
    }

    .accordion-button:not(.collapsed)::after {
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16' fill='%23198754'%3e%3cpath fill-rule='evenodd' d='M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z'/%3e%3c/svg%3e");
    }
</style>
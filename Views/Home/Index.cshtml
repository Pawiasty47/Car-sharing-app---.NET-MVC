@model HomeIndexViewModel
@{
    ViewData["Title"] = "Strona główna";
}

<!-- CTA -->
<section class="text-center py-5">
    <h1 class="fw-bold text-success">Wóz albo Przewóz</h1>
    <p class="lead text-muted">
        Wspólne przejazdy • niższe koszty • mniej spalin
    </p>

    <a class="btn btn-success btn-lg me-2" asp-controller="Rides" asp-action="Index">
        <i class="bi bi-search"></i> Szukaj przejazdu
    </a>
</section>


<!-- STATYSTYKI -->
<section class="container my-5">
    <div class="row text-center">
        <div class="col-md-6 mb-3">
            <h2 class="text-success fw-bold">@Model.UsersCount</h2>
            <p class="text-muted">Zarejestrowanych użytkowników</p>
        </div>
        <div class="col-md-6 mb-3">
            <h2 class="text-success fw-bold">@Model.RidesCount</h2>
            <p class="text-muted">Przejazdów w historii</p>
        </div>
    </div>
</section>


<!-- INFO WG ROLI -->
@if (Model.IsAdmin)
{
    <div class="alert alert-warning text-center container">
        👑 Zalogowany jako <strong>Administrator</strong> —
        <a asp-controller="Admin" asp-action="Users" class="alert-link">Panel admina</a>
    </div>
}

@if (Model.IsDriver && !Model.IsAdmin)
{
    <div class="alert alert-success text-center container">
        🚗 Jesteś <strong>kierowcą</strong> — możesz dodawać i edytować przejazdy
    </div>
}

@if (!Model.IsDriver && !Model.IsAdmin)
{
    <div class="alert alert-warning text-center container">
        🚗 Chcesz więcej? —
        <a asp-controller="DriverProfile" asp-action="Index" class="alert-link">Zostań kierowcą!</a>
    </div>
}

<!-- SPONSORZY -->
<section class="container my-3">
    <h3 class="text-center mb-2">Nasi partnerzy</h3>

    <div id="sponsorsCarousel"
         class="carousel slide"
         data-bs-ride="carousel"
         data-bs-interval="5000">
        <div class="carousel-inner text-center">
            <div class="carousel-item active">
                <img src="https://zakupersi.com/wp-content/uploads/2015/12/lech.png"
                     class="img-fluid"
                     alt="Sponsor 1">
            </div>
            <div class="carousel-item">
                <img src="https://tyskie.pl/assets/img/tyskie-og.png"
                     class="img-fluid"
                     alt="Sponsor 2">
            </div>
        </div>
    </div>
</section>

<!-- FAQ -->
<section class="container my-5">
    <h3 class="text-center mb-4 text-success fw-bold">FAQ</h3>

    <div class="accordion shadow-sm" id="faqAccordion">

        <!-- Pytanie 1 -->
        <div class="accordion-item border-0 border-bottom">
            <h2 class="accordion-header">
                <button class="accordion-button fw-semibold" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                    Czy korzystanie z serwisu jest darmowe?
                </button>
            </h2>
            <div id="faq1" class="accordion-collapse collapse show" data-bs-parent="#faqAccordion">
                <div class="accordion-body text-muted">
                    Tak - rejestracja i przeglądanie przejazdów są bezpłatne.
                </div>
            </div>
        </div>

        <!-- Pytanie 2 -->
        <div class="accordion-item border-0 border-bottom">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed fw-semibold" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                    Jak mogę zostać kierowcą?
                </button>
            </h2>
            <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                <div class="accordion-body text-muted">
                    Wystarczy założyć konto, wejść w profil, kliknąć "Zostań kierowcą" i wypełnić formularz.
                </div>
            </div>
        </div>

        <!-- Pytanie 3 -->
        <div class="accordion-item border-0">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed fw-semibold" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">
                    Jak mogę wybrać przejazd?
                </button>
            </h2>
            <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                <div class="accordion-body text-muted">
                    Naciśnij przycisk "Wyszukaj przejazd" w menu lub na stronie głównej i znajdź ofertę, która Ci odpowiada.
                </div>
            </div>
        </div>

    </div>
</section>

<!-- STYLE -->
<style>
    /* Sponsorzy */
    #sponsorsCarousel .carousel-inner img {
        width: 400px;
        height: 300px;
        object-fit: contain;
        margin: 0 auto;
    }

    /* FAQ  */
    .accordion-button:not(.collapsed) {
        background-color: #e9f7ef;
        color: #198754;
        box-shadow: inset 0 -1px 0 rgba(0,0,0,.125);
    }

    .accordion-button:focus {
        border-color: #198754;
        box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.25);
    }

    .accordion-button:not(.collapsed)::after {
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16' fill='%23198754'%3e%3cpath fill-rule='evenodd' d='M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z'/%3e%3c/svg%3e");
    }
</style>

@model HomeIndexViewModel
@{
    ViewData["Title"] = "Strona główna";
}

<!-- CTA -->
<section class="text-center py-5">
    <h1 class="fw-bold text-success">Wóz albo Przewóz</h1>
    <p class="lead text-muted">
        Wspólne przejazdy • niższe koszty • mniej spalin
    </p>

    <a class="btn btn-success btn-lg me-2" asp-controller="Rides" asp-action="Index">
        🔍 Szukaj przejazdu
    </a>
</section>


<!-- STATYSTYKI -->
<section class="container my-5">
    <div class="row text-center">
        <div class="col-md-6 mb-3">
            <h2 class="text-success fw-bold">@Model.UsersCount</h2>
            <p class="text-muted">Zarejestrowanych użytkowników</p>
        </div>
        <div class="col-md-6 mb-3">
            <h2 class="text-success fw-bold">@Model.RidesCount</h2>
            <p class="text-muted">Przejazdów w historii</p>
        </div>
    </div>
</section>


<!-- INFO WG ROLI -->
@if (Model.IsAdmin)
{
    <div class="alert alert-warning text-center container">
        👑 Zalogowany jako <strong>Administrator</strong> —
        <a asp-controller="Admin" asp-action="Users">Panel admina</a>
    </div>
}

@if (Model.IsDriver)
{
    <div class="alert alert-success text-center container">
        🚗 Jesteś <strong>kierowcą</strong> — możesz dodawać i edytować przejazdy
    </div>
}

else
{
    <div class="alert alert-warning text-center container">
        🚗 Chcesz więcej? —
        <a asp-controller="DriverProfile" asp-action="Index">Zostań kierowcą!</a>
    </div>
}

<!-- SPONSORZY -->
<section class="container my-3">
    <h3 class="text-center mb-2">Nasi partnerzy</h3>

    <div id="sponsorsCarousel"
         class="carousel slide"
         data-bs-ride="carousel"
         data-bs-interval="5000">
        <div class="carousel-inner text-center">
            <div class="carousel-item active">
                <img src="https://zakupersi.com/wp-content/uploads/2015/12/lech.png"
                     class="img-fluid"
                     alt="Sponsor 1">
            </div>
            <div class="carousel-item">
                <img src="https://tyskie.pl/assets/img/tyskie-og.png"
                     class="img-fluid"
                     alt="Sponsor 2">
            </div>
        </div>
    </div>
</section>

<style>
    #sponsorsCarousel .carousel-inner img {
        width: 400px;
        height: 300px;
        object-fit: contain;
        margin: 0 auto;
    }
</style>

<!-- FAQ -->
<section class="container my-5">
    <h3 class="text-center mb-4">FAQ</h3>

    <div class="accordion" id="faqAccordion">
        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button"
                        data-bs-toggle="collapse"
                        data-bs-target="#faq1">
                    Czy korzystanie z serwisu jest darmowe?
                </button>
            </h2>

            <div id="faq1"
                 class="accordion-collapse collapse show">
                <div class="accordion-body">
                    Tak - rejestracja i przeglądanie przejazdów są bezpłatne.
                </div>
            </div>
        </div>
    </div>

    <div class="accordion" id="faqAccordion">
        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button"
                        data-bs-toggle="collapse"
                        data-bs-target="#faq2">
                    Jak mogę zostać kierowcą?
                </button>
            </h2>

            <div id="faq2"
                 class="accordion-collapse collapse show">
                <div class="accordion-body">
                    Wystarczy założyć konto, wejść w profil, kliknąć "Zostań kierowcą" i wypełnić formularz.
                </div>
            </div>
        </div>
    </div>

    <div class="accordion" id="faqAccordion">
        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button"
                        data-bs-toggle="collapse"
                        data-bs-target="#faq3">
                    Jak mogę wybrać przejazd?
                </button>
            </h2>

            <div id="faq3"
                 class="accordion-collapse collapse show">
                <div class="accordion-body">
                    Naciśnij przycisk "Wyszukaj przejazd" i znajdź czego potrzebujesz.
                </div>
            </div>
        </div>
    </div>
</section>

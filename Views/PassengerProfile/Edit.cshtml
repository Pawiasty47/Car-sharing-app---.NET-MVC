@model projekt_zespołowy.Models.ViewModels.PassengerProfileViewModel

@{
    ViewData["Title"] = "Edycja Profilu";
}

<div class="container mt-4">
    <h2>Edycja Profilu</h2>
    <hr />

    <form asp-action="Edit" method="post" enctype="multipart/form-data">

        <div class="mb-4 text-center">
            @if (Model.ExistingProfilePicture != null)
            {
                <img src="data:image/*;base64,@(Convert.ToBase64String(Model.ExistingProfilePicture))"
                     class="rounded-circle mb-3" style="width: 150px; height: 150px; object-fit: cover; border: 3px solid #198754;" />
            }
            else
            {
                <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center mx-auto mb-3"
                     style="width: 150px; height: 150px; font-size: 50px;">
                    👤
                </div>
            }
            <div class="mb-3">
                <label asp-for="ProfilePictureFile" class="form-label">Zmień zdjęcie profilowe</label>
                <input asp-for="ProfilePictureFile" class="form-control" type="file" accept=".png,.jpg,.jpeg" />
            </div>

        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <label asp-for="FirstName" class="form-label">Imię</label>
                <input asp-for="FirstName" class="form-control" placeholder="Wpisz swoje imię" />
                <span asp-validation-for="FirstName" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="LastName" class="form-label">Nazwisko</label>
                <input asp-for="LastName" class="form-control" placeholder="Wpisz swoje nazwisko" />
                <span asp-validation-for="LastName" class="text-danger"></span>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <label asp-for="Email" class="form-label">Adres e-mail</label>
                <input asp-for="Email" class="form-control" placeholder="np. jan.kowalski@email.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="PhoneNumber" class="form-label">Numer telefonu</label>
                <input asp-for="PhoneNumber" class="form-control" placeholder="np. 123 456 789" />
                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
            </div>
        </div>

        <div class="card p-4 border-0 shadow-sm bg-light mt-4">
            <h5 class="mb-4"><i class="bi bi-person-lines-fill me-2"></i>Moje preferencje w podróży</h5>

            <div class="form-check form-switch mb-3">
                <input class="form-check-input" type="checkbox" asp-for="PrefersMusic" id="PrefersMusic" />
                <label class="form-check-label user-select-none" for="PrefersMusic">
                    Lubię słuchać muzyki podczas jazdy
                </label>
            </div>

            <div class="form-check form-switch mb-3">
                <input class="form-check-input" type="checkbox" asp-for="AcceptsPets" id="AcceptsPets" />
                <label class="form-check-label user-select-none" for="AcceptsPets">
                    Akceptuję podróżowanie ze zwierzętami
                </label>
            </div>

            <div class="form-check form-switch mb-3">
                <input class="form-check-input" type="checkbox" asp-for="AcceptsEating" id="AcceptsEating" />
                <label class="form-check-label user-select-none" for="AcceptsEating">
                    Nie przeszkadza mi jedzenie w samochodzie
                </label>
            </div>

            <div class="form-check form-switch mb-3">
                <input class="form-check-input" type="checkbox" asp-for="PrefersQuietRide" id="PrefersQuietRide" />
                <label class="form-check-label user-select-none" for="PrefersQuietRide">
                    Preferuję ciszę (odpoczynek zamiast rozmowy)
                </label>
            </div>

            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" asp-for="IsSmoker" id="IsSmoker" />
                <label class="form-check-label user-select-none" for="IsSmoker">
                    Jestem osobą palącą
                </label>
            </div>
        </div>

        <button type="submit" class="btn btn-success btn-lg mt-4 w-100">
            <i class="bi bi-save me-2"></i>Zapisz zmiany
        </button>
    </form>
</div>
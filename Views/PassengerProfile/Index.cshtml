@model projekt_zespołowy.Models.ViewModels.PassengerProfileViewModel

@{
    ViewData["Title"] = "Mój Profil";
}

<div class="container mt-5">

    <div class="card shadow-sm border-0">
        <div class="card-body p-5">

            <div class="row align-items-center mb-5">
                <div class="col-md-3 text-center mb-3 mb-md-0">
                    @if (Model.ExistingProfilePicture != null)
                    {
                        <img src="data:image/*;base64,@(Convert.ToBase64String(Model.ExistingProfilePicture))"
                             class="rounded-circle shadow-sm"
                             style="width: 150px; height: 150px; object-fit: cover;" />
                    }
                    else
                    {
                        <div class="rounded-circle bg-light d-inline-flex align-items-center justify-content-center text-secondary shadow-sm"
                             style="width: 150px; height: 150px;">
                            <i class="bi bi-person-fill" style="font-size: 5rem;"></i>
                        </div>
                    }
                </div>

                <div class="col-md-9">
                    <h2 class="fw-bold text-success mb-1">@Model.FirstName @Model.LastName</h2>
                    <p class="text-muted mb-1">@Model.Email</p>
                    <p class="text-muted mb-3">@(Model.PhoneNumber ?? "Brak numeru telefonu")</p>

                    @if (!User.IsInRole("Admin"))
                    {
                        <div class="d-flex flex-wrap gap-3 mt-3">
                            @if (Model.IsDriver)
                            {
                                <div class="border rounded px-3 py-2 text-center">
                                    <small class="text-muted d-block text-uppercase" style="font-size: 0.7rem;">Kierowca</small>
                                    <span class="fw-bold text-success">
                                        @if (Model.DriverRating.HasValue && Model.DriverRating.Value > 0)
                                        {
                                            <span>@Model.DriverRating.Value.ToString("0.0") / 5</span>
                                        }
                                        else
                                        {
                                            <span>Brak ocen</span>
                                        }
                                    </span>
                                </div>
                            }

                            <div class="border rounded px-3 py-2 text-center">
                                <small class="text-muted d-block text-uppercase" style="font-size: 0.7rem;">Pasażer</small>
                                <span class="fw-bold text-success">
                                    @if (Model.PassengerRating > 0)
                                    {
                                        <span>@Model.PassengerRating.ToString("0.0") / 5</span>
                                    }
                                    else
                                    {
                                        <span>Brak ocen</span>
                                    }
                                </span>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <hr class="my-4 text-muted opacity-25" />

            <div class="mb-5">
                <h4 class="fw-bold mb-3 text-secondary">Preferencje podróży</h4>

                <div class="d-flex flex-wrap gap-2">
                    @* Wyświetlamy TYLKO pozytywne cechy (gdy true) *@

                    @if (Model.PrefersMusic)
                    {
                        <span class="badge bg-success fw-normal px-3 py-2">Lubię muzykę</span>
                    }

                    @if (Model.AcceptsPets)
                    {
                        <span class="badge bg-success fw-normal px-3 py-2">Akceptuję zwierzęta</span>
                    }

                    @if (Model.AcceptsEating)
                    {
                        <span class="badge bg-success fw-normal px-3 py-2">Można jeść</span>
                    }

                    @* Bazując na Twoim starym kodzie: true = "Chętnie porozmawiam" *@
                    @if (Model.PrefersQuietRide)
                    {
                        <span class="badge bg-success fw-normal px-3 py-2">Lubię rozmawiać</span>
                    }

                    @* Bazując na Twoim starym kodzie: true = "Palący" *@
                    @if (Model.IsSmoker)
                    {
                        <span class="badge bg-secondary fw-normal px-3 py-2">Palący</span>
                    }

                    @* Jeśli wszystko jest na false (nowy użytkownik), wyświetl info *@
                    @if (!Model.PrefersMusic && !Model.AcceptsPets && !Model.AcceptsEating && !Model.PrefersQuietRide && !Model.IsSmoker)
                    {
                        <span class="text-muted fst-italic">
                            Nie ustawiono jeszcze preferencji. Kliknij "Edytuj profil", aby dodać informacje o sobie.
                        </span>
                    }
                </div>
            </div>

            <div class="mb-5">
                <h4 class="fw-bold mb-3 text-secondary">
                    <i class="bi bi-wallet2 me-2"></i> Mój Portfel
                </h4>

                <ul class="nav nav-tabs mb-3" id="walletTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="wallet-tab" data-bs-toggle="tab" data-bs-target="#wallet" type="button" role="tab" aria-controls="wallet" aria-selected="true">Portfel</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="transactions-tab" data-bs-toggle="tab" data-bs-target="#transactions" type="button" role="tab" aria-controls="transactions" aria-selected="false">Historia transakcji</button>
                    </li>
                </ul>

                <div class="tab-content" id="walletTabsContent">
                    <div class="tab-pane fade show active" id="wallet" role="tabpanel" aria-labelledby="wallet-tab">
                        <div class="row g-4">
                            <div class="col-md-5">
                                <div class="card bg-light border-0 shadow-sm p-4 h-100 d-flex justify-content-center align-items-center text-center">
                                    <small class="text-muted text-uppercase fw-bold">Dostępne środki</small>
                                    <h2 class="display-6 fw-bold text-success mb-0">
                                        @Model.Balance.ToString("C2")
                                    </h2>
                                </div>
                            </div>

                            <div class="col-md-7">
                                <div class="card border-0 shadow-sm p-4 h-100">
                                    <div class="alert alert-info py-2 mb-3" style="font-size: 0.85rem;">
                                        <i class="bi bi-info-circle me-1"></i> System obsługuje <strong>tylko pełne kwoty</strong> (bez groszy).
                                    </div>

                                    <form asp-action="AddFunds" method="post" class="row g-2 mb-3">
                                        @Html.AntiForgeryToken()
                                        <div class="col-8">
                                            <div class="input-group">
                                                <input type="number" name="amount" class="form-control"
                                                       placeholder="Kwota" step="1" min="1" required
                                                       oninvalid="this.setCustomValidity('Można wpłacać i wypłacać tylko pełne kwoty (bez groszy).')"
                                                       oninput="this.setCustomValidity('')">
                                                <span class="input-group-text">zł</span>
                                            </div>
                                        </div>
                                        <div class="col-4">
                                            <button type="submit" class="btn btn-success w-100">
                                                <i class="bi bi-plus-circle me-1"></i> Doładuj
                                            </button>
                                        </div>
                                    </form>

                                    <form asp-action="WithdrawFunds" method="post" class="row g-2">
                                        @Html.AntiForgeryToken()
                                        <div class="col-8">
                                            <div class="input-group">
                                                <input type="number" name="amount" class="form-control"
                                                       placeholder="Kwota" step="1" min="1" required
                                                       oninvalid="this.setCustomValidity('Można wpłacać i wypłacać tylko pełne kwoty (bez groszy).')"
                                                       oninput="this.setCustomValidity('')">
                                                <span class="input-group-text">zł</span>
                                            </div>
                                        </div>
                                        <div class="col-4">
                                            <button type="submit" class="btn btn-outline-danger w-100">
                                                <i class="bi bi-dash-circle me-1"></i> Wypłać
                                            </button>
                                        </div>
                                    </form>

                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="transactions" role="tabpanel" aria-labelledby="transactions-tab">
                        @if (ViewBag.Transactions == null || !((List<projekt_zespołowy.Models.Transaction>)ViewBag.Transactions).Any())
                        {
                            <div class="alert alert-light border text-center py-4 text-muted">
                                Brak zapisanych transakcji.
                            </div>
                        }
                        else
                        {
                            <div class="list-group">
                                @foreach (var t in (List<projekt_zespołowy.Models.Transaction>)ViewBag.Transactions)
                                {
                                    <div class="list-group-item d-flex justify-content-between align-items-center">
                                        <div>
                                            <div class="fw-bold">@t.Type.ToString()</div>
                                            <div class="small text-muted">@t.Description</div>
                                        </div>
                                        <div class="text-end">
                                            <div class="fw-bold @(t.Type == projekt_zespołowy.Models.TransactionType.Deposit || t.Type == projekt_zespołowy.Models.TransactionType.Earned ? "text-success" : "text-danger")">
                                                @((t.Type == projekt_zespołowy.Models.TransactionType.Withdrawal || t.Type == projekt_zespołowy.Models.TransactionType.Spent) ? "-" : "+")@t.Amount.ToString("C2")
                                            </div>
                                            <div class="small text-muted">@t.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="d-flex flex-wrap gap-3">
                <a asp-controller="Booking" asp-action="Index" class="btn btn-success px-4">
                    <i class="bi bi-ticket-perforated me-2"></i> Moje rezerwacje
                </a>

                <a asp-action="Edit" class="btn btn-outline-success px-4">
                    <i class="bi bi-pencil me-2"></i> Edytuj profil
                </a>

                @if (!User.IsInRole("Driver"))
                {
                    <a asp-controller="DriverApplication" asp-action="Index" class="btn btn-outline-dark px-4">
                        <i class="bi bi-car-front me-2"></i> Zostań kierowcą
                    </a>
                }
                else
                {
                    <a asp-controller="DriverProfile" asp-action="Index" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-speedometer2 me-2"></i> Profil kierowcy
                    </a>
                }
            </div>

            @if (User.IsInRole("Admin"))
            {
                <div class="mt-5 pt-3 border-top">
                    <div class="alert alert-light border d-flex align-items-center justify-content-between">
                        <div>
                            <strong class="text-danger"><i class="bi bi-shield-lock me-2"></i>Panel Administratora</strong>
                            <div class="small text-muted">Zarządzanie użytkownikami i systemem</div>
                        </div>
                        <a asp-controller="Admin" asp-action="Users" class="btn btn-sm btn-outline-danger">
                            Przejdź do panelu
                        </a>
                    </div>
                </div>
            }

        </div>
    </div>

    <div class="mt-5 mb-5">
        <h4 class="fw-bold mb-4 text-secondary">Zakończone przejazdy (Pasażer)</h4>

        @if (ViewBag.CompletedBookings == null || ViewBag.CompletedBookings.Count == 0)
        {
            <div class="alert alert-light border text-center py-4 text-muted">
                Brak zakończonych przejazdów w historii.
            </div>
        }
        else
        {
            <div class="list-group">
                @foreach (var booking in ViewBag.CompletedBookings)
                {
                    <div class="list-group-item border-0 shadow-sm mb-2 rounded p-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="mb-1 text-success">
                                    @booking.Ride.StartLocation.City <i class="bi bi-arrow-right-short mx-1"></i> @booking.Ride.EndLocation.City
                                </h5>
                                <small class="text-muted">
                                    <i class="bi bi-calendar-event me-1"></i> @booking.Ride.DepartureTime.ToString("dd.MM.yyyy, HH:mm")
                                </small>
                            </div>
                            <div class="text-end text-muted small">
                                <i class="bi bi-person me-1"></i> @booking.Ride.Driver.User.FirstName @booking.Ride.Driver.User.LastName
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
    <div class="mt-5">
        <h4 class="fw-bold mb-4 text-secondary">
            <i class="bi bi-chat-dots me-2"></i> Moje czaty
        </h4>

        @if (ViewBag.Chats == null || !((List<Chat>)ViewBag.Chats).Any())
        {
            <div class="alert alert-light border text-center py-4 text-muted">
                Nie masz jeszcze żadnych aktywnych czatów.
            </div>
        }
        else
        {
            <div class="list-group">
                @foreach (var chat in (List<Chat>)ViewBag.Chats)
                {
                    <a asp-controller="Chat"
                       asp-action="RideChat"
                       asp-route-rideId="@chat.RideId"
                       class="list-group-item list-group-item-action shadow-sm mb-2 rounded border-0">

                        <div class="d-flex justify-content-between align-items-center">

                            <div>
                                <h5 class="mb-1 text-primary">
                                    @chat.Ride.StartLocation.City
                                    <i class="bi bi-arrow-right-short mx-1"></i>
                                    @chat.Ride.EndLocation.City
                                </h5>

                                <small class="text-muted">
                                    <i class="bi bi-calendar-event me-1"></i>
                                    @chat.Ride.DepartureTime.ToString("dd.MM.yyyy HH:mm")
                                </small>
                            </div>

                            <div>
                                <span class="badge bg-primary">
                                    <i class="bi bi-chat"></i>
                                </span>
                            </div>

                        </div>
                    </a>
                }
            </div>
        }
    </div>
</div>
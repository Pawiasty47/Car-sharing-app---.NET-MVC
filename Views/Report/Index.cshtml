@model projekt_zespołowy.Models.ViewModels.AdminReportsViewModel

@{
    ViewData["Title"] = "Zgłoszenia";
}

<div class="container mt-4">
    <!-- Przycisk powrotu do listy użytkowników -->
    <div class="mb-3">
        <a asp-controller="Admin" asp-action="Users" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Wróć do użytkowników
        </a>
    </div>

    <h2 class="fw-bold mb-4">
        <i class="bi bi-shield-lock-fill me-2"></i>Zgłoszenia użytkowników
    </h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!Model.Reports.Any() && !Model.DriverApplications.Any())
    {
        <div class="alert alert-success">
            <i class="bi bi-check-circle me-2"></i>Brak zgłoszeń!
        </div>
    }
    else
    {
        @* Sekcja: Wnioski o zostanie kierowcą *@
        @if (Model.DriverApplications.Any())
        {
            <h4 class="mb-3">Wnioski o status kierowcy</h4>
            <div class="table-responsive mb-4">
                <table class="table table-hover shadow-sm border align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Data</th>
                            <th>Użytkownik</th>
                            <th>Dane</th>
                            <th>Pojazd</th>
                            <th class="text-end">Akcja</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var app in Model.DriverApplications)
                        {
                            <tr>
                                <td>@app.ApplicationDate.ToString("dd.MM.yyyy HH:mm")</td>
                                <td>@app.User?.Email<br /><small>@app.FirstName @app.LastName</small></td>
                                <td>
                                    PESEL: @app.PESEL<br />
                                    Prawo jazdy: @app.DriverLicenseNumber (@app.LicenseCategories)
                                </td>
                                <td>@app.Vehicle?.Make @app.Vehicle?.Model (@app.Vehicle?.RegistrationNumber)</td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        <form asp-controller="AdminDriver" asp-action="Approve" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@app.Id" />
                                            <button class="btn btn-success btn-sm">Akceptuj</button>
                                        </form>

                                        <button class="btn btn-danger btn-sm" onclick="rejectApp(@app.Id)">Odrzuć</button>

                                        <form id="rejectForm-@app.Id" asp-controller="AdminDriver" asp-action="Reject" method="post" style="display:none;">
                                            <input type="hidden" name="id" value="@app.Id" />
                                            <input type="hidden" name="reason" id="reason-@app.Id" />
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @* Sekcja: Zgłoszenia błędów/raporty *@
        <h4 class="mb-3">Zgłoszenia systemowe</h4>
        <div class="table-responsive">
            <table class="table table-hover shadow-sm border align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Data</th>
                        <th>Kategoria</th>
                        <th>Użytkownik</th>
                        <th style="width: 35%">Treść</th>
                        <th>Status</th>
                        <th class="text-end">Akcja</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Reports)
                    {
                        <tr class="@(item.IsResolved ? "table-light text-muted" : "")">
                            <td>@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                            <td><span class="badge bg-secondary">@item.Category</span></td>
                            <td>
                                @if (item.User != null)
                                {
                                    @item.User.Email
                                }
                                else
                                {
                                    <span class="fst-italic text-muted">Anonim</span>
                                }
                            </td>
                            <td>@item.Description</td>
                            <td>
                                @if (item.IsResolved)
                                {
                                    <span class="badge bg-success">Załatwione</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Oczekuje</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <!-- Przycisk Załatwione/Cofnij -->
                                    <form asp-action="MarkAsResolved" method="post">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        @if (!item.IsResolved)
                                        {
                                            <button class="btn btn-success btn-sm" title="Oznacz jako załatwione">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-outline-secondary btn-sm" title="Oznacz jako w toku">
                                                <i class="bi bi-arrow-counterclockwise"></i>
                                            </button>
                                        }
                                    </form>

                                    <!-- NOWY PRZYCISK: USUŃ -->
                                    <form asp-action="Delete" method="post">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button class="btn btn-danger btn-sm" title="Usuń trwale"
                                                onclick="return confirm('Czy na pewno chcesz usunąć to zgłoszenie? Tego nie da się cofnąć.');">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<script>
    function rejectApp(id) {
        let reason = prompt("Podaj powód odrzucenia:");
        if (reason !== null) {
            document.getElementById('reason-' + id).value = reason;
            document.getElementById('rejectForm-' + id).submit();
        }
    }
</script>

@model IEnumerable<projekt_zespołowy.Models.RideSubscription>

@{
    ViewData["Title"] = "Subskrypcje przejazdów";
}

<div class="container mt-4">
    <h2 class="fw-bold text-primary mb-4">
        <i class="bi bi-bell-fill me-2"></i>Subskrypcje przejazdów
    </h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <h5 class="mb-3">Dodaj nową subskrypcję</h5>

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Skąd</label>
                        <input type="text" name="fromCity" class="form-control" placeholder="np. Warszawa" required />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Dokąd</label>
                        <input type="text" name="toCity" class="form-control" placeholder="np. Kraków" required />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Kiedy</label>
                        <input type="date" name="rideDate" class="form-control" required />
                    </div>
                </div>

                <div class="mt-3">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-plus-circle me-2"></i>Zapisz subskrypcję
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <h5 class="mb-3">Moje zapisane subskrypcje</h5>

            @if (!Model.Any())
            {
                <div class="alert alert-info mb-0">
                    Nie masz jeszcze żadnych zapisanych subskrypcji.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Skąd</th>
                                <th>Dokąd</th>
                                <th>Data</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.FromCity</td>
                                    <td>@item.ToCity</td>
                                    <td>@item.RideDate.ToString("dd.MM.yyyy")</td>
                                    <td class="text-end">
                                        <form asp-action="Delete" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                Usuń
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
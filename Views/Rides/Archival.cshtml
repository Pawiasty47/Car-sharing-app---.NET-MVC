@model IEnumerable<projekt_zespołowy.Models.OfferedRide>
@using Microsoft.AspNetCore.Identity
@using projekt_zespołowy.Models

@inject UserManager<User> UserManager

@{
    ViewData["Title"] = "Przejazdy archiwalne";
    var currentUserId = UserManager.GetUserId(User);
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-secondary">
                <i class="bi bi-archive-fill me-2"></i>Przejazdy archiwalne
            </h2>
            <p class="text-muted">Historia zakończonych lub minionych przejazdów.</p>
        </div>

        <a asp-action="Index" class="btn btn-primary btn-lg shadow-sm">
            <i class="bi bi-arrow-left-circle me-2"></i>Wróć do dostępnych
        </a>
    </div>

    <div class="card bg-light border-0 shadow-sm mb-5">
        <div class="card-body p-4">
            <form asp-action="Archival" method="get">
                <div class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label fw-bold small text-uppercase text-muted">Skąd</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white"><i class="bi bi-geo-alt"></i></span>
                            <input type="text" name="searchFrom" class="form-control"
                                   placeholder="Miasto startu..." value="@ViewData["CurrentFilterFrom"]" />
                        </div>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold small text-uppercase text-muted">Dokąd</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white"><i class="bi bi-geo-alt-fill"></i></span>
                            <input type="text" name="searchTo" class="form-control"
                                   placeholder="Miasto docelowe..." value="@ViewData["CurrentFilterTo"]" />
                        </div>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold small text-uppercase text-muted">Data</label>
                        <input type="date" name="searchDate" class="form-control"
                               value="@ViewData["CurrentFilterDate"]" />
                    </div>

                    <div class="col-md-3">
                        @if (User.Identity.IsAuthenticated && (User.IsInRole("Driver") || User.IsInRole("Admin")))
                        {
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="onlyMine" name="onlyMine" value="true" @(ViewBag.IsMyRidesMode == true ? "checked" : "") />
                                <label class="form-check-label small" for="onlyMine">Tylko moje przejazdy</label>
                            </div>
                        }

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-secondary">
                                <i class="bi bi-search me-2"></i>Szukaj
                            </button>
                            <a asp-action="Archival" class="btn btn-outline-secondary btn-sm">
                                Wyczyść filtry
                            </a>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-secondary text-center p-5 rounded-3 shadow-sm" role="alert">
            <h4 class="alert-heading"><i class="bi bi-inbox me-2"></i>Brak archiwalnych przejazdów</h4>
            @if (ViewData["CurrentFilterFrom"] != null || ViewData["CurrentFilterTo"] != null || ViewData["CurrentFilterDate"] != null)
            {
                <p>Niestety, nie znaleziono archiwalnych przejazdów spełniających Twoje kryteria.</p>
                <a asp-action="Archival" class="btn btn-outline-dark mt-2">Pokaż całe archiwum</a>
            }
            else
            {
                <p>W bazie danych nie ma jeszcze żadnych zakończonych przejazdów.</p>
            }
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                var isOwner = currentUserId != null && item.DriverId.ToString() == currentUserId;
                var isAdmin = User.IsInRole("Admin");

                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0 hover-effect bg-light">
                        <div class="card-header bg-transparent border-bottom-0 pt-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="badge bg-secondary rounded-pill">
                                    <i class="bi bi-calendar-check me-1"></i>
                                    @item.DepartureTime.ToString("dd.MM.yyyy")
                                </span>
                                <span class="fw-bold text-muted fs-5">
                                    @item.PricePerSeat.ToString("C")
                                </span>
                            </div>
                        </div>

                        <div class="card-body opacity-75">
                            <div class="d-flex align-items-center mb-3">
                                <div class="text-center me-3">
                                    <div class="fw-bold fs-5">@item.DepartureTime.ToString("HH:mm")</div>
                                </div>
                                <div class="flex-grow-1 border-top border-2 border-secondary position-relative text-center" style="height: 0;">
                                    <i class="bi bi-check-circle-fill position-absolute top-0 start-50 translate-middle bg-light text-secondary" style="margin-top: -1px;"></i>
                                </div>
                                <div class="text-center ms-3">
                                    @if (item.ArrivalTime.HasValue)
                                    {
                                        <div class="fw-bold fs-5">@item.ArrivalTime.Value.ToString("HH:mm")</div>
                                    }
                                    else
                                    {
                                        <div class="fw-bold fs-5">--:--</div>
                                    }
                                </div>
                            </div>

                            <h5 class="card-title text-center fw-bold mb-3 text-secondary">
                                @(item.StartLocation?.City ?? "Nieznane")
                                <i class="bi bi-arrow-right mx-2 text-muted"></i>
                                @(item.EndLocation?.City ?? "Nieznane")
                            </h5>
                            <hr class="text-muted opacity-25">
                            <p class="card-text small text-muted mb-2 text-center">
                                <i class="bi bi-car-front-fill me-1"></i> @(item.Vehicle?.Make ?? "Brak") @(item.Vehicle?.Model)
                            </p>
                            <p class="card-text small text-center text-muted">
                                <strong>Status:</strong>
                                @if (item.Status == RideStatus.Completed)
                                {
                                    <span class="badge bg-success">Zakończony</span>
                                }
                                else
                                {
                                    <span class="badge bg-dark">@item.Status.ToString()</span>
                                }
                            </p>
                        </div>

                        <div class="card-footer bg-transparent border-top-0 pb-3 pt-0">
                            <div class="d-grid gap-2 d-flex justify-content-center mt-2">
                                <!--
                                                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm">
                                    <i class="bi bi-info-circle"></i> Szczegóły
                                </a>
                                -->
                                @if ((isOwner || isAdmin) && item.Status == RideStatus.Completed)
                                {
                                    <a asp-action="Summary" asp-route-id="@item.Id" class="btn btn-outline-info btn-sm ms-1">
                                        <i class="bi bi-file-earmark-text"></i> Podsumowanie
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .hover-effect {
        transition: transform 0.2s ease-in-out;
    }

        .hover-effect:hover {
            transform: translateY(-5px);
        }
</style>
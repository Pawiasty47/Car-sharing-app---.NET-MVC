@model IEnumerable<projekt_zespołowy.Models.OfferedRide>
@using projekt_zespołowy.Models

@{
    ViewData["Title"] = "Moje zakończone przejazdy";
}

<div class="container mt-4">
    <h2 class="mb-4"><i class="bi bi-list-check me-2 text-primary"></i>Moje przejazdy — zakończone</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info text-center p-5">
            <i class="bi bi-calendar-x fs-1"></i>
            <h4 class="mt-3">Brak zakończonych przejazdów.</h4>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var ride in Model)
            {
                var seats = ride.SeatsTaken;
                var total = (ride.PricePerSeat * seats);
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-header bg-secondary text-white d-flex justify-content-between align-items-center">
                            <span class="fw-bold">COMPLETED</span>
                            <small>@ride.DepartureTime.ToString("dd.MM.yyyy")</small>
                        </div>

                        <div class="card-body">
                            <h5 class="card-title text-center mb-3">
                                @(ride.StartLocation?.City ?? "—")
                                <i class="bi bi-arrow-right mx-2 text-muted"></i>
                                @(ride.EndLocation?.City ?? "—")
                            </h5>

                            <ul class="list-unstyled small">
                                <li class="mb-2"><i class="bi bi-calendar-event me-2 text-primary"></i><strong>Data:</strong> @ride.DepartureTime.ToString("dd.MM.yyyy HH:mm")</li>
                                <li class="mb-2"><i class="bi bi-people me-2 text-primary"></i><strong>Miejsca:</strong> @seats</li>
                                <li class="mb-2"><i class="bi bi-cash-coin me-2 text-primary"></i><strong>Cena:</strong> @total.ToString("C")</li>
                                <li class="mb-2"><i class="bi bi-person-badge me-2 text-primary"></i><strong>Kierowca:</strong> @ride.Driver?.User?.FirstName</li>
                            </ul>

                            @if (!string.IsNullOrEmpty(ride.Notes))
                            {
                                <div class="mb-3">
                                    <input class="form-control" readonly value="Twoja uwaga: &quot;@ride.Notes&quot;" />
                                </div>
                            }
                        </div>

                        <div class="card-footer bg-white border-top-0 d-flex justify-content-start">
                            <a asp-action="Details" asp-route-id="@ride.Id" class="btn btn-outline-primary btn-sm">
                                Szczegóły trasy
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
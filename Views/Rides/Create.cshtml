@model projekt_zespołowy.Models.ViewModels.AddRideViewModel

@{
    ViewData["Title"] = "Dodaj nowy przejazd";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-success text-white">
                <h3 class="mb-0"><i class="bi bi-signpost-2 me-2"></i>Dodaj nowy przejazd</h3>
            </div>
            <div class="card-body p-4">

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        <strong>Ups! Wystąpiły błędy:</strong>
                        <div asp-validation-summary="All" class="mb-0"></div>
                    </div>
                }

                <form asp-action="Create" method="post">

                    <h5 class="text-muted border-bottom pb-2 mb-3">1. Wybierz pojazd</h5>
                    <div class="mb-4">
                        <label asp-for="SelectedVehicleId" class="form-label fw-bold">Twój pojazd</label>
                        <select asp-for="SelectedVehicleId" class="form-select"
                                asp-items="@(new SelectList(Model.AvailableVehicles, "Id", "Model"))">
                            <option value="">-- Wybierz samochód --</option>
                        </select>
                        <span asp-validation-for="SelectedVehicleId" class="text-danger"></span>
                        <div class="form-text">Jeśli lista jest pusta, najpierw dodaj pojazd w zakładce "Dodaj pojazd".</div>
                    </div>

                    <h5 class="text-muted border-bottom pb-2 mb-3">2. Trasa</h5>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="card bg-light border-0 h-100">
                                <div class="card-body">
                                    <h6 class="fw-bold text-success"><i class="bi bi-geo-alt-fill me-1"></i> Miejsce Startu</h6>

                                    <div class="mb-2">
                                        <label asp-for="StartLocation.City" class="form-label small">Miasto</label>
                                        <input asp-for="StartLocation.City" class="form-control check-address" data-prefix="StartLocation" placeholder="np. Warszawa" />
                                        <span asp-validation-for="StartLocation.City" class="text-danger"></span>
                                    </div>

                                    <div class="mb-2">
                                        <label asp-for="StartLocation.Address" class="form-label small">Ulica / Adres</label>
                                        <input asp-for="StartLocation.Address" class="form-control check-address" data-prefix="StartLocation" placeholder="np. Aleje Jerozolimskie" />
                                        <span asp-validation-for="StartLocation.Address" class="text-danger"></span>
                                    </div>

                                    <div class="mb-2">
                                        <label asp-for="StartLocation.Name" class="form-label small">Nazwa punktu</label>
                                        <input asp-for="StartLocation.Name" class="form-control" placeholder="np. Dworzec Centralny" />
                                        <span asp-validation-for="StartLocation.Name" class="text-danger"></span>
                                    </div>

                                    <!-- Miejsce na błąd walidacji mapy -->
                                    <span id="StartLocation-error" class="text-danger small fw-bold mt-2" style="display: none;"></span>

                                    @if (Model?.StartLocation != null && Model.StartLocation.Latitude != 0)
                                    {
                                        <input type="hidden" id="StartLat" name="StartLocation.Latitude" value="@Model.StartLocation.Latitude.ToString("F6")" />
                                    }
                                    else
                                    {
                                        <input type="hidden" id="StartLat" value="" />
                                    }

                                    @if (Model?.StartLocation != null && Model.StartLocation.Id != Guid.Empty)
                                    {
                                        <input type="hidden" id="StartLocation_Id" name="StartLocation.Id" value="@Model.StartLocation.Id.ToString()" />
                                    }
                                    else
                                    {
                                        <input type="hidden" id="StartLocation_Id" value="" />
                                    }

                                    @if (Model?.StartLocation != null && Model.StartLocation.Longtitude != 0)
                                    {
                                        <input type="hidden" id="StartLng" name="StartLocation.Longtitude" value="@Model.StartLocation.Longtitude.ToString("F6")" />
                                    }
                                    else
                                    {
                                        <input type="hidden" id="StartLng" value="" />
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="card bg-light border-0 h-100">
                                <div class="card-body">
                                    <h6 class="fw-bold text-danger"><i class="bi bi-geo-alt-fill me-1"></i> Miejsce Docelowe</h6>

                                    <div class="mb-2">
                                        <label asp-for="EndLocation.City" class="form-label small">Miasto</label>
                                        <input asp-for="EndLocation.City" class="form-control check-address" data-prefix="EndLocation" placeholder="np. Kraków" />
                                        <span asp-validation-for="EndLocation.City" class="text-danger"></span>
                                    </div>

                                    <div class="mb-2">
                                        <label asp-for="EndLocation.Address" class="form-label small">Ulica / Adres</label>
                                        <input asp-for="EndLocation.Address" class="form-control check-address" data-prefix="EndLocation" placeholder="np. Pawia" />
                                        <span asp-validation-for="EndLocation.Address" class="text-danger"></span>
                                    </div>

                                    <div class="mb-2">
                                        <label asp-for="EndLocation.Name" class="form-label small">Nazwa punktu</label>
                                        <input asp-for="EndLocation.Name" class="form-control" placeholder="np. Galeria Krakowska" />
                                        <span asp-validation-for="EndLocation.Name" class="text-danger"></span>
                                    </div>

                                    <!-- Miejsce na błąd walidacji mapy -->
                                    <span id="EndLocation-error" class="text-danger small fw-bold mt-2" style="display: none;"></span>

                                    @if (Model?.EndLocation != null && Model.EndLocation.Latitude != 0)
                                    {
                                        <input type="hidden" id="EndLat" name="EndLocation.Latitude" value="@Model.EndLocation.Latitude.ToString("F6")" />
                                    }
                                    else
                                    {
                                        <input type="hidden" id="EndLat" value="" />
                                    }

                                    @if (Model?.EndLocation != null && Model.EndLocation.Id != Guid.Empty)
                                    {
                                        <input type="hidden" id="EndLocation_Id" name="EndLocation.Id" value="@Model.EndLocation.Id.ToString()" />
                                    }
                                    else
                                    {
                                        <input type="hidden" id="EndLocation_Id" value="" />
                                    }

                                    @if (Model?.EndLocation != null && Model.EndLocation.Longtitude != 0)
                                    {
                                        <input type="hidden" id="EndLng" name="EndLocation.Longtitude" value="@Model.EndLocation.Longtitude.ToString("F6")" />
                                    }
                                    else
                                    {
                                        <input type="hidden" id="EndLng" value="" />
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card mt-3">
                        <div class="card-body">
                            <h6 class="fw-bold">Wybierz punkty na mapie</h6>
                            <p class="small text-muted">Kliknij na mapie, aby ustawić punkt startu, następnie kliknij ponownie aby ustawić punkt docelowy. Użyj przycisku "Resetuj" aby usunąć znaczniki.</p>
                            <div id="rideMap" style="height: 400px; width: 100%;"></div>
                            <div class="mt-2 d-flex gap-2">
                                <button type="button" id="resetMapBtn" class="btn btn-outline-secondary btn-sm">Resetuj</button>
                                <div class="ms-auto small">
                                    <span class="fw-bold">Start:</span> <span id="startCoords">-</span>
                                    &nbsp;•&nbsp;
                                    <span class="fw-bold">Cel:</span> <span id="endCoords">-</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <h5 class="text-muted border-bottom pb-2 mb-3 mt-4">3. Szczegóły przejazdu</h5>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="DepartureTime" class="form-label fw-bold">Data i godzina wyjazdu</label>
                            <input asp-for="DepartureTime" class="form-control" type="datetime-local"
                                   value="@DateTime.Now.AddHours(1).ToString("yyyy-MM-ddTHH:mm")" />
                            <span asp-validation-for="DepartureTime" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ArrivalTime" class="form-label">Przewidywany czas dojazdu</label>
                            <input asp-for="ArrivalTime" class="form-control" type="datetime-local" />
                            <span asp-validation-for="ArrivalTime" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row g-3 mt-2">
                        <div class="col-md-4">
                            <label asp-for="SeatsOffered" class="form-label fw-bold">Liczba miejsc</label>
                            <input asp-for="SeatsOffered" class="form-control" min="1" max="8" />
                            <span asp-validation-for="SeatsOffered" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="PricePerSeat" class="form-label fw-bold">Cena (PLN)</label>
                            <div class="input-group">
                                <input asp-for="PricePerSeat" class="form-control" type="number" step="0.01" />
                                <span class="input-group-text">zł</span>
                            </div>
                            <span asp-validation-for="PricePerSeat" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <div class="form-check mb-2">
                                <input asp-for="IsFlexiblePrice" class="form-check-input" type="checkbox" />
                                <label asp-for="IsFlexiblePrice" class="form-check-label">Cena do negocjacji</label>
                            </div>
                        </div>
                    </div>

                    <div class="mt-3">
                        <label asp-for="Notes" class="form-label">Uwagi dla pasażerów</label>
                        <textarea asp-for="Notes" class="form-control" rows="3" placeholder="np. nie palę, zabieram małego psa..."></textarea>
                        <span asp-validation-for="Notes" class="text-danger"></span>
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn btn-success btn-lg">
                            <i class="bi bi-check-circle-fill me-2"></i> Opublikuj przejazd
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Anuluj</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        (function(){
            // Map initialization
            var startInputLat = document.getElementById('StartLat');
            var startInputLng = document.getElementById('StartLng');
            var endInputLat = document.getElementById('EndLat');
            var endInputLng = document.getElementById('EndLng');

            var startCoordsLabel = document.getElementById('startCoords');
            var endCoordsLabel = document.getElementById('endCoords');

            var map = L.map('rideMap').setView([52.0, 19.0], 6);
            if (navigator && navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(function(pos){
                    var lat = pos.coords.latitude;
                    var lng = pos.coords.longitude;
                    map.setView([lat, lng], 12);
                }, function(){
                    // ignore
                }, { timeout: 5000 });
            }
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
            }).addTo(map);

            var pickupMarker = null;
            var destMarker = null;

            function updateLabels(){
                startCoordsLabel.textContent = (startInputLat.value && startInputLng.value) ? startInputLat.value + ', ' + startInputLng.value : '-';
                endCoordsLabel.textContent = (endInputLat.value && endInputLng.value) ? endInputLat.value + ', ' + endInputLng.value : '-';
            }

            // Zmiana do obsługi wymuszania nadpisania (forceOverwrite)
            function setPickup(latlng, forceOverwrite){
                if (typeof forceOverwrite === 'undefined') forceOverwrite = false;

                if(pickupMarker){
                    pickupMarker.setLatLng(latlng);
                } else {
                    pickupMarker = L.marker(latlng, { draggable: true }).addTo(map).bindPopup('Punkt startu');
                    pickupMarker.on('dragend', function(e){
                        var nl = e.target.getLatLng();
                        startInputLat.value = nl.lat.toFixed(6);
                        startInputLng.value = nl.lng.toFixed(6);
                        var idEl = document.getElementById('StartLocation_Id'); if(idEl) idEl.dataset.needsCreate = '1';
                        reverseGeocode(nl, 'StartLocation', true); // drag nadpisuje inputy!
                        updateLabels();
                    });
                }
                startInputLat.value = latlng.lat.toFixed(6);
                startInputLng.value = latlng.lng.toFixed(6);
                reverseGeocode(latlng, 'StartLocation', forceOverwrite);
                updateLabels();
            }

            function setDest(latlng, forceOverwrite){
                if (typeof forceOverwrite === 'undefined') forceOverwrite = false;

                if(destMarker){
                    destMarker.setLatLng(latlng);
                } else {
                    destMarker = L.marker(latlng, { draggable: true }).addTo(map).bindPopup('Punkt docelowy');
                    destMarker.on('dragend', function(e){
                        var nl = e.target.getLatLng();
                        endInputLat.value = nl.lat.toFixed(6);
                        endInputLng.value = nl.lng.toFixed(6);
                        var idEl = document.getElementById('EndLocation_Id'); if(idEl) idEl.dataset.needsCreate = '1';
                        reverseGeocode(nl, 'EndLocation', true); // drag nadpisuje inputy!
                        updateLabels();
                    });
                }
                endInputLat.value = latlng.lat.toFixed(6);
                endInputLng.value = latlng.lng.toFixed(6);
                reverseGeocode(latlng, 'EndLocation', forceOverwrite);
                updateLabels();
            }

            function reverseGeocode(latlng, prefix, forceOverwrite){
                if (typeof forceOverwrite === 'undefined') forceOverwrite = false;

                var url = 'https://nominatim.openstreetmap.org/reverse?format=jsonv2&addressdetails=1&lat=' + encodeURIComponent(latlng.lat) + '&lon=' + encodeURIComponent(latlng.lng);
                var nameEl = document.getElementById(prefix + '_Name');
                var cityEl = document.getElementById(prefix + '_City');
                var addrEl = document.getElementById(prefix + '_Address');

                fetch(url, { headers: { 'Accept': 'application/json' } })
                    .then(function(response){
                        if(!response.ok) throw new Error('geocode failed');
                        return response.json();
                    })
                    .then(function(data){
                        var address = data && data.address ? data.address : {};
                        var city = address.city || address.town || address.village || address.county || '';
                        var road = address.road || '';
                        var house = address.house_number || '';
                        var postcode = address.postcode || '';

                        var addrParts = [];
                        if(road) addrParts.push(road);
                        if(house) addrParts.push(house);
                        if(postcode) addrParts.push(postcode);
                        var addressStr = addrParts.join(' ');

                        // Fill if empty OR if forceOverwrite is true (zależnie od tego, czy użytkownik użył mapy)
                        if(nameEl && (forceOverwrite || !nameEl.value || nameEl.value.trim() === '')){
                            if(data && data.name) nameEl.value = data.name;
                            else if(address.amenity) nameEl.value = address.amenity;
                            else if(road) nameEl.value = road;
                            else nameEl.value = 'Punkt (' + latlng.lat.toFixed(4) + ', ' + latlng.lng.toFixed(4) + ')';
                        }
                        if(cityEl && (forceOverwrite || !cityEl.value || cityEl.value.trim() === '')){
                            cityEl.value = city || 'Nieznane';
                        }
                        if(addrEl && (forceOverwrite || !addrEl.value || addrEl.value.trim() === '')){
                            addrEl.value = addressStr || (data && data.display_name) || (latlng.lat.toFixed(6) + ', ' + latlng.lng.toFixed(6));
                        }

                        // Ukryj błędy, jeśli uzupełniamy z poprawnego geocodingu mapy
                        if(forceOverwrite) {
                            if(cityEl) cityEl.classList.remove('is-invalid');
                            if(addrEl) addrEl.classList.remove('is-invalid');
                            var errorSpan = document.getElementById(prefix + '-error');
                            if(errorSpan) errorSpan.style.display = 'none';
                        }

                        try {
                            var idEl = document.getElementById(prefix + '_Id');
                            if(idEl && (!idEl.value || idEl.value.trim() === '')){
                                idEl.dataset.needsCreate = '1';
                            }
                        } catch(e) { /* ignore */ }
                    })
                    .catch(function(err){
                        if(nameEl && (!nameEl.value || nameEl.value.trim() === '')){
                            nameEl.value = 'Punkt (' + latlng.lat.toFixed(4) + ', ' + latlng.lng.toFixed(4) + ')';
                        }
                        if(cityEl && (!cityEl.value || cityEl.value.trim() === '')){
                            cityEl.value = 'Nieznane';
                        }
                        if(addrEl && (!addrEl.value || addrEl.value.trim() === '')){
                            addrEl.value = latlng.lat.toFixed(6) + ', ' + latlng.lng.toFixed(6);
                        }
                    });
            }

            // preload
            if(startInputLat.value && startInputLng.value){
                setPickup(L.latLng(parseFloat(startInputLat.value), parseFloat(startInputLng.value)), false);
                map.setView([parseFloat(startInputLat.value), parseFloat(startInputLng.value)], 12);
            }
            if(endInputLat.value && endInputLng.value){
                setDest(L.latLng(parseFloat(endInputLat.value), parseFloat(endInputLng.value)), false);
            }

            map.on('click', function(e){
                if(!pickupMarker){
                    setPickup(e.latlng, true); // Zawsze nadpisuj input przy kliknięciu w mapę!
                } else if(!destMarker){
                    setDest(e.latlng, true);
                } else {
                    setDest(e.latlng, true);
                }
            });

            document.getElementById('resetMapBtn').addEventListener('click', function(){
                if(pickupMarker){ map.removeLayer(pickupMarker); pickupMarker = null; }
                if(destMarker){ map.removeLayer(destMarker); destMarker = null; }
                startInputLat.value = '';
                startInputLng.value = '';
                endInputLat.value = '';
                endInputLng.value = '';

                var startName = document.getElementById('StartLocation_Name');
                var startCity = document.getElementById('StartLocation_City');
                var startAddr = document.getElementById('StartLocation_Address');
                var startId = document.getElementById('StartLocation_Id');
                if(startName) startName.value = '';
                if(startCity) startCity.value = '';
                if(startAddr) startAddr.value = '';
                if(startId) startId.value = '';

                var endName = document.getElementById('EndLocation_Name');
                var endCity = document.getElementById('EndLocation_City');
                var endAddr = document.getElementById('EndLocation_Address');
                var endId = document.getElementById('EndLocation_Id');
                if(endName) endName.value = '';
                if(endCity) endCity.value = '';
                if(endAddr) endAddr.value = '';
                if(endId) endId.value = '';

                // Czyszczenie ew. ostrzeżeń
                ['StartLocation', 'EndLocation'].forEach(prefix => {
                    var errSpan = document.getElementById(prefix + '-error');
                    var cEl = document.getElementById(prefix + '_City');
                    var aEl = document.getElementById(prefix + '_Address');
                    if(errSpan) errSpan.style.display = 'none';
                    if(cEl) cEl.classList.remove('is-invalid');
                    if(aEl) aEl.classList.remove('is-invalid');
                });

                updateLabels();
            });

            // NOWOŚĆ: Synchronizacja Wpisywany Tekst -> Mapa
            const addressInputs = document.querySelectorAll('.check-address');
            addressInputs.forEach(input => {
                input.addEventListener('blur', async function() {
                    let prefix = this.getAttribute('data-prefix'); // StartLocation lub EndLocation
                    let cityEl = document.getElementById(prefix + '_City');
                    let addrEl = document.getElementById(prefix + '_Address');
                    let errorSpan = document.getElementById(prefix + '-error');

                    if (!cityEl || !cityEl.value) return;

                    let query = `${addrEl && addrEl.value ? addrEl.value + ', ' : ''}${cityEl.value}`;

                    try {
                        let response = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(query)}&limit=1`);
                        let data = await response.json();

                        if (data.length === 0) {
                            errorSpan.style.display = 'block';
                            errorSpan.innerHTML = `❌ Nie znaleziono adresu "${query}". Popraw dane lub wskaż miejsce bezpośrednio na mapie.`;
                            cityEl.classList.add('is-invalid');
                            if(addrEl) addrEl.classList.add('is-invalid');

                            // Usuń z mapy i wyczyść coords, żeby zablokować wysłanie głupot
                            if (prefix === 'StartLocation') {
                                startInputLat.value = ''; startInputLng.value = '';
                                if(pickupMarker){ map.removeLayer(pickupMarker); pickupMarker = null; }
                            } else {
                                endInputLat.value = ''; endInputLng.value = '';
                                if(destMarker){ map.removeLayer(destMarker); destMarker = null; }
                            }
                            updateLabels();
                        } else {
                            errorSpan.style.display = 'none';
                            cityEl.classList.remove('is-invalid');
                            if(addrEl) addrEl.classList.remove('is-invalid');

                            let lat = parseFloat(data[0].lat);
                            let lon = parseFloat(data[0].lon);
                            let latlng = L.latLng(lat, lon);

                            map.setView(latlng, 12);

                            // Umieść marker (false oznacza "nie nadpisuj nam tego, co właśnie użytkownik wpisał z palca")
                            if (prefix === 'StartLocation') {
                                setPickup(latlng, false);
                            } else {
                                setDest(latlng, false);
                            }
                        }
                    } catch (error) {
                        console.error("Geocoding error", error);
                    }
                });
            });

            var form = document.querySelector('form[asp-action="Create"]') || document.querySelector('form');
            function isLocationFilled(prefix){
                var lat = document.getElementById(prefix + 'Lat');
                var lng = document.getElementById(prefix + 'Lng');
                var name = document.getElementById(prefix + '_Name');
                var city = document.getElementById(prefix + '_City');
                var addr = document.getElementById(prefix + '_Address');
                if(!lat || !lng || !name || !city || !addr) return false;
                return lat.value.trim() !== '' && lng.value.trim() !== '' && name.value.trim() !== '' && city.value.trim() !== '' && addr.value.trim() !== '';
            }

            if(form){
                function createLocationPoint(prefix){
                    return new Promise(function(resolve){
                        try{
                            var idEl = document.getElementById(prefix + '_Id');
                            var nameEl = document.getElementById(prefix + '_Name');
                            var cityEl = document.getElementById(prefix + '_City');
                            var addrEl = document.getElementById(prefix + '_Address');
                            var latEl = document.getElementById(prefix + 'Lat');
                            var lngEl = document.getElementById(prefix + 'Lng');
                            if(!idEl || !(idEl.dataset && idEl.dataset.needsCreate)) return resolve(null);
                            var payload = {
                                Name: nameEl ? nameEl.value : '',
                                City: cityEl ? cityEl.value : '',
                                Address: addrEl ? addrEl.value : '',
                                Latitude: latEl ? parseFloat(latEl.value) : null,
                                Longtitude: lngEl ? parseFloat(lngEl.value) : null
                            };
                            fetch('/Rides/CreateLocationPoint', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify(payload)
                            }).then(function(res){ return res.json(); })
                              .then(function(json){
                                  if(json && json.id){
                                      idEl.value = json.id;
                                      delete idEl.dataset.needsCreate;
                                      return resolve(json.id);
                                  }
                                  return resolve(null);
                              }).catch(function(){ return resolve(null); });
                        }catch(e){ return resolve(null); }
                    });
                }

                form.addEventListener('submit', function(e){
                    var startOk = isLocationFilled('StartLocation');
                    var endOk = isLocationFilled('EndLocation');
                    if(!startOk || !endOk){
                        e.preventDefault();
                        e.stopPropagation();
                        var msg = 'Proszę ustawić oba punkty na mapie i upewnić się, że pola Nazwa/Miasto/Adres są wypełnione poprawnym adresem.';
                        alert(msg);
                        return false;
                    }

                    var startIdEl = document.getElementById('StartLocation_Id');
                    var endIdEl = document.getElementById('EndLocation_Id');
                    var needsStartCreate = startIdEl && startIdEl.dataset && startIdEl.dataset.needsCreate;
                    var needsEndCreate = endIdEl && endIdEl.dataset && endIdEl.dataset.needsCreate;

                    if(needsStartCreate || needsEndCreate){
                        e.preventDefault();
                        Promise.all([
                            needsStartCreate ? createLocationPoint('StartLocation') : Promise.resolve(null),
                            needsEndCreate ? createLocationPoint('EndLocation') : Promise.resolve(null)
                        ]).then(function(){
                            form.submit();
                        });
                        return false;
                    }

                    return true;
                });
            }

            updateLabels();
        })();
    </script>
}
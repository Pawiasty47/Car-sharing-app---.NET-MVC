@model projekt_zespołowy.Models.OfferedRide

@{
    ViewData["Title"] = "Usuń przejazd";
}

<h1>Usuń przejazd</h1>

<div class="alert alert-danger" role="alert">
    <h4 class="alert-heading">Uwaga!</h4>
    <p>Czy na pewno chcesz usunąć ten przejazd? Tej operacji nie można cofnąć.</p>
</div>

<div>
    <h4>Szczegóły przejazdu</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            Pojazd
        </dt>
        <dd class="col-sm-10">
            @* Użycie ?. (null-conditional) zapobiega błędom, jeśli pojazd jest nullem *@
            @(Model.Vehicle?.Make ?? "Brak danych") @(Model.Vehicle?.Model)
            (@(Model.Vehicle?.RegistrationNumber ?? "Brak nr rej."))
        </dd>

        <dt class="col-sm-2">
            Trasa
        </dt>
        <dd class="col-sm-10">
            @* Bezpieczne wyświetlanie miast *@
            @(Model.StartLocation?.City ?? "Nieznane") &rarr; @(Model.EndLocation?.City ?? "Nieznane")
        </dd>

        <dt class="col-sm-2">
            Data wyjazdu
        </dt>
        <dd class="col-sm-10">
            @Model.DepartureTime.ToString("g")
        </dd>
    </dl>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Usuń</button>
    <a asp-action="Index" class="btn btn-secondary">Anuluj</a>
</form>
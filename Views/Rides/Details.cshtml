@model projekt_zespołowy.Models.OfferedRide
@using Microsoft.AspNetCore.Identity
@using projekt_zespołowy.Models

@inject UserManager<User> UserManager
@{
    ViewData["Title"] = "Szczegóły przejazdu";

    var currentUser = await UserManager.GetUserAsync(User);
    var isDriver = currentUser != null && (Model.DriverId == currentUser.Id || User.IsInRole("Admin"));

    var bookings = ViewBag.Bookings as List<Booking> ?? new List<Booking>();
    var myBooking = currentUser != null ? bookings.FirstOrDefault(b => b.PassengerUserId == currentUser.Id) : null;
    var isBooked = myBooking != null;

    var seatsAvailable = Model.SeatsOffered - Model.SeatsTaken;
    var hasBookings = bookings.Any();

    var passengerRatings = ViewBag.PassengerRatings as System.Collections.Generic.Dictionary<Guid, double> ?? new System.Collections.Generic.Dictionary<Guid, double>();
}

<div class="container mt-4">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model.Status == RideStatus.Cancelled)
    {
        <div class="alert alert-danger shadow-sm border-danger border-2 text-center p-4 mb-4">
            <i class="bi bi-x-octagon-fill fs-1 d-block mb-2"></i>
            <h4 class="alert-heading fw-bold">Przejazd został odwołany!</h4>
            <p class="mb-0">Kierowca awaryjnie odwołał tę trasę. Żadne nowe rezerwacje nie są możliwe.</p>
        </div>
    }

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 mb-4 @(Model.Status == RideStatus.Cancelled ? "opacity-75" : "")">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0"><i class="bi bi-info-circle me-2"></i>Szczegóły Przejazdu</h4>
                    <span class="badge bg-white text-primary fs-6 d-flex align-items-center gap-2">
                        @Model.PricePerSeat.ToString("C") / os.
                        @* ZMIANA 3: Znaczek do negocjacji *@
                        @if (Model.IsFlexiblePrice)
                        {
                            <span class="badge bg-warning text-dark fs-7" title="Cena do negocjacji"><i class="bi bi-tag-fill me-1"></i>Do negocjacji</span>
                        }
                    </span>
                </div>
                <div class="card-body">
                    <div class="row text-center align-items-center mb-4">
                        <div class="col-5">
                            <h3 class="fw-bold text-primary">@Model.StartLocation.City</h3>
                            <p class="text-muted mb-0">@Model.StartLocation.Address</p>
                            <span class="badge bg-light text-dark border">
                                @Model.DepartureTime.ToString("dd.MM.yyyy HH:mm")
                            </span>
                        </div>
                        <div class="col-2">
                            <i class="bi bi-arrow-right fs-1 text-muted"></i>
                        </div>
                        <div class="col-5">
                            <h3 class="fw-bold text-primary">@Model.EndLocation.City</h3>
                            <p class="text-muted mb-0">@Model.EndLocation.Address</p>
                            @if (Model.ArrivalTime.HasValue)
                            {
                                <span class="badge bg-light text-dark border">
                                    @Model.ArrivalTime.Value.ToString("dd.MM.yyyy HH:mm")
                                </span>
                            }
                        </div>
                    </div>

@section Scripts {
    <script>
        (function(){
            // Render coordinates if present, otherwise null so we can detect missing data
            var startLat = @(Model.StartLocation != null && Model.StartLocation.Latitude != 0 ? Model.StartLocation.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture) : "null");
            var startLng = @(Model.StartLocation != null && Model.StartLocation.Longtitude != 0 ? Model.StartLocation.Longtitude.ToString(System.Globalization.CultureInfo.InvariantCulture) : "null");
            var endLat = @(Model.EndLocation != null && Model.EndLocation.Latitude != 0 ? Model.EndLocation.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture) : "null");
            var endLng = @(Model.EndLocation != null && Model.EndLocation.Longtitude != 0 ? Model.EndLocation.Longtitude.ToString(System.Globalization.CultureInfo.InvariantCulture) : "null");

            function fetchCoords(query){
                return fetch('https://nominatim.openstreetmap.org/search?format=jsonv2&limit=1&q=' + encodeURIComponent(query), { headers: { 'Accept': 'application/json' } })
                    .then(function(r){ if(!r.ok) throw new Error('geocode failed'); return r.json(); })
                    .then(function(js){ if(js && js.length){ return { lat: parseFloat(js[0].lat), lon: parseFloat(js[0].lon) }; } return null; })
                    .catch(function(){ return null; });
            }

            function buildQueryFromModel(prefix){
                if(prefix === 'start'){
                    var name = '@(Model.StartLocation?.Name ?? "")'.trim();
                    var addr = '@(Model.StartLocation?.Address ?? "")'.trim();
                    var city = '@(Model.StartLocation?.City ?? "")'.trim();
                    return [name, addr, city].filter(Boolean).join(' ');
                } else {
                    var name2 = '@(Model.EndLocation?.Name ?? "")'.trim();
                    var addr2 = '@(Model.EndLocation?.Address ?? "")'.trim();
                    var city2 = '@(Model.EndLocation?.City ?? "")'.trim();
                    return [name2, addr2, city2].filter(Boolean).join(' ');
                }
            }

            function initMapWithCoords(sLat, sLng, eLat, eLng){
                var map = L.map('rideDetailsMap').setView([ (sLat+eLat)/2, (sLng+eLng)/2 ], 8);
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    maxZoom: 19,
                    attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
                }).addTo(map);

                var startMarker = L.marker([sLat, sLng]).addTo(map).bindPopup('Start: ' + '@(Model.StartLocation?.Name ?? Model.StartLocation?.City ?? "Start")');
                var endMarker = L.marker([eLat, eLng]).addTo(map).bindPopup('Cel: ' + '@(Model.EndLocation?.Name ?? Model.EndLocation?.City ?? "Cel")');

                var bounds = L.latLngBounds([ [sLat, sLng], [eLat, eLng] ]);
                map.fitBounds(bounds.pad(0.2));

                L.polyline([[sLat, sLng], [eLat, eLng]], {color: 'blue', weight: 3, opacity: 0.6}).addTo(map);
            }

            (function ensureAndInit(){
                var sLat = (startLat !== null) ? Number(startLat) : null;
                var sLng = (startLng !== null) ? Number(startLng) : null;
                var eLat = (endLat !== null) ? Number(endLat) : null;
                var eLng = (endLng !== null) ? Number(endLng) : null;

                var promises = [];
                if(sLat == null || sLng == null){
                    var q = buildQueryFromModel('start');
                    if(q) promises.push(fetchCoords(q).then(function(res){ if(res){ sLat = res.lat; sLng = res.lon; } }));
                }
                if(eLat == null || eLng == null){
                    var q2 = buildQueryFromModel('end');
                    if(q2) promises.push(fetchCoords(q2).then(function(res){ if(res){ eLat = res.lat; eLng = res.lon; } }));
                }

                Promise.all(promises).then(function(){
                    if(sLat != null && sLng != null && eLat != null && eLng != null){
                        initMapWithCoords(sLat, sLng, eLat, eLng);
                    } else {
                        // if we have only one point, center map on that
                        if(sLat != null && sLng != null){
                            var map = L.map('rideDetailsMap').setView([sLat, sLng], 12);
                            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom:19, attribution: '&copy; OpenStreetMap' }).addTo(map);
                            L.marker([sLat, sLng]).addTo(map).bindPopup('Start').openPopup();
                        } else if(eLat != null && eLng != null){
                            var map = L.map('rideDetailsMap').setView([eLat, eLng], 12);
                            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom:19, attribution: '&copy; OpenStreetMap' }).addTo(map);
                            L.marker([eLat, eLng]).addTo(map).bindPopup('Cel').openPopup();
                        }
                    }
                }).catch(function(){ /* ignore */ });
            })();
        })();
    </script>
}

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="bi bi-map me-2"></i>Trasa na mapie</h5>
                </div>
                <div class="card-body p-0">
                    <div id="rideDetailsMap" style="height: 320px; width: 100%;"></div>
                </div>
            </div>
                    <hr />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="d-flex align-items-center p-3 bg-light rounded h-100">
                                <div class="fs-1 me-3">👤</div>
                                <div>
                                    <small class="text-muted text-uppercase fw-bold">Kierowca</small>
                                    <h5 class="mb-0">@Model.Driver?.User?.FirstName @Model.Driver?.User?.LastName</h5>
                                    <small class="text-warning">★ @Model.Driver?.Rating / 5.0</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="d-flex align-items-center p-3 bg-light rounded h-100">
                                <div class="fs-1 me-3">🚗</div>
                                <div>
                                    <small class="text-muted text-uppercase fw-bold">Pojazd</small>
                                    <h5 class="mb-0">@Model.Vehicle?.Make @Model.Vehicle?.Model</h5>
                                    <small class="text-muted">@Model.Vehicle?.Color</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Notes))
                    {
                        <div class="mt-4">
                            <h6 class="fw-bold"><i class="bi bi-chat-quote me-2"></i>Uwagi:</h6>
                            <p class="fst-italic text-muted">"@Model.Notes"</p>
                        </div>
                    }
                </div>
            </div>

            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Wróć do wyszukiwarki
            </a>
        </div>

        <div class="col-lg-4">

            @if (isDriver)
            {
                // --- WIDOK DLA KIEROWCY ---

                // 1. Sekcja: Prośby oczekujące (PENDING)
                var pendingBookings = bookings.Where(b => b.Status == projekt_zespołowy.Models.BookingStatus.Pending).ToList();

                if (pendingBookings.Any() && Model.Status != RideStatus.Cancelled)
                {
                    <div class="card border-warning shadow-sm mb-4">
                        <div class="card-header bg-warning text-dark">
                            <h5 class="mb-0 fw-bold"><i class="bi bi-hourglass-split me-2"></i>Oczekujące prośby</h5>
                        </div>
                        <div class="list-group list-group-flush">
                            @foreach (var b in pendingBookings)
                            {
                                <div class="list-group-item">
                                    <div class="mb-2">
                                        <strong>@b.Passenger?.FirstName @b.Passenger?.LastName</strong>
                                        <br />
                                        <small class="text-muted">Chce rezerwować: <span class="fw-bold text-dark">@b.SeatsRequested msc.</span></small>

                                        @if (!string.IsNullOrEmpty(b.CommentByPassenger))
                                        {
                                            <div class="alert alert-light border p-2 mt-2 mb-1 small">
                                                <i class="bi bi-chat-quote-fill me-1 text-primary"></i>
                                                <span class="fst-italic">"@b.CommentByPassenger"</span>
                                            </div>
                                        }
                                    </div>

                                    <div class="d-flex gap-2">
                                        <form asp-controller="Booking" asp-action="Accept" method="post" class="flex-grow-1">
                                            <input type="hidden" name="bookingId" value="@b.Id" />
                                            <button type="submit" class="btn btn-sm btn-success w-100">
                                                <i class="bi bi-check-lg"></i> Akceptuj
                                            </button>
                                        </form>

                                        <button type="button" class="btn btn-sm btn-outline-danger w-100 flex-grow-1"
                                                data-bs-toggle="modal" data-bs-target="#rejectModal-@b.Id">
                                            <i class="bi bi-x-lg"></i> Odrzuć
                                        </button>
                                    </div>
                                </div>

                                <div class="modal fade" id="rejectModal-@b.Id" tabindex="-1" aria-hidden="true">
                                    <div class="modal-dialog modal-dialog-centered">
                                        <div class="modal-content">
                                            <form asp-controller="Booking" asp-action="Reject" method="post">
                                                <div class="modal-header bg-danger text-white">
                                                    <h5 class="modal-title">Odrzuć rezerwację</h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                </div>
                                                <div class="modal-body text-start">
                                                    <p>Czy na pewno odrzucić pasażera <strong>@b.Passenger?.FirstName</strong>?</p>
                                                    <input type="hidden" name="bookingId" value="@b.Id" />

                                                    <div class="mb-3">
                                                        <label class="form-label fw-bold small">Powód (opcjonalny):</label>
                                                        <textarea name="reason" class="form-control" rows="3" placeholder="np. Brak miejsca na duży bagaż..."></textarea>
                                                    </div>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Anuluj</button>
                                                    <button type="submit" class="btn btn-danger">Potwierdź</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                // 2. Sekcja: Pasażerowie zatwierdzeni (CONFIRMED)
                var confirmedBookings = bookings.Where(b => b.Status == projekt_zespołowy.Models.BookingStatus.Confirmed).ToList();

                <div class="card border-success shadow-sm mb-3">
                    <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-people-fill me-2"></i>Pasażerowie</h5>
                        <div>
                            @if (Model.Status == RideStatus.Published || Model.Status == RideStatus.InProgress)
                            {
                                <form asp-action="Complete" method="post" class="d-inline ms-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-light" onclick="return confirm('Zakończyć przejazd?')" title="Zakończ przejazd jako zrealizowany">
                                        <i class="bi bi-check2-circle"></i>
                                    </button>
                                </form>

                                @* ZMIANA 2: AWARYJNE ODWOŁANIE PRZEJAZDU DLA KIEROWCY *@
                                <form asp-action="CancelRide" method="post" class="d-inline ms-1">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger border-white" onclick="return confirm('CZY NA PEWNO chcesz awaryjnie odwołać ten przejazd? Wszyscy pasażerowie stracą rezerwacje i otrzymają powiadomienie.')" title="Awaryjne odwołanie przejazdu">
                                        <i class="bi bi-x-octagon-fill"></i> Odwołaj trasę
                                    </button>
                                </form>
                            }
                            else if (Model.Status == RideStatus.Completed)
                            {
                                <a asp-action="Summary" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-light ms-2" title="Podsumowanie">
                                    <i class="bi bi-file-earmark-text"></i>
                                </a>
                            }
                        </div>
                    </div>

                    <div class="card-body p-0">
                        @if (confirmedBookings.Any())
                        {
                            <div class="list-group list-group-flush">
                                @foreach (var b in confirmedBookings)
                                {
                                    <div class="list-group-item">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <h6 class="mb-0 fw-bold">@b.Passenger?.FirstName @b.Passenger?.LastName</h6>
                                                <p class="mb-1 text-muted small">
                                                    <i class="bi bi-telephone me-1"></i> @(b.Passenger?.PhoneNumber ?? "Brak telefonu")
                                                </p>
                                                @if (!string.IsNullOrEmpty(b.CommentByPassenger))
                                                {
                                                    <small class="fst-italic text-primary">"@b.CommentByPassenger"</small>
                                                }
                                            </div>
                                            <span class="badge bg-primary rounded-pill">@b.SeatsRequested msc.</span>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-center p-4 text-muted">
                                <i class="bi bi-person-slash fs-1"></i>
                                <p class="mt-2 mb-0">Brak potwierdzonych pasażerów.</p>
                            </div>
                        }
                    </div>
                    <div class="card-footer text-muted small text-center">
                        Zajęte miejsca: @Model.SeatsTaken / @Model.SeatsOffered
                    </div>
                </div>
            }
            else
            {
                // --- WIDOK DLA PASAŻERA ---
                <div class="card shadow-sm sticky-top" style="top: 20px; z-index: 1;">
                    <div class="card-body text-center">
                        <h5 class="text-uppercase text-muted small fw-bold mb-3">Dostępność miejsc</h5>

                        @if (Model.Status == RideStatus.Cancelled)
                        {
                            <div class="alert alert-secondary border-0 bg-light">
                                <i class="bi bi-slash-circle fs-1 d-block mb-2 text-danger"></i>
                                <h4 class="text-muted">Przejazd Odwołany</h4>
                                <p class="mb-0 small">Kierowca odwołał ten przejazd.</p>
                            </div>
                        }
                        else if (myBooking != null && myBooking.Status != projekt_zespołowy.Models.BookingStatus.Cancelled)
                        {
                            if (myBooking.Status == projekt_zespołowy.Models.BookingStatus.Confirmed)
                            {
                                <div class="alert alert-success border-success">
                                    <i class="bi bi-ticket-perforated-fill fs-1 d-block mb-2"></i>
                                    <h4 class="alert-heading">Rezerwacja potwierdzona!</h4>
                                    <p class="mb-0">Twoje miejsce jest zarezerwowane.</p>
                                    <a asp-controller="Booking" asp-action="Index" class="btn btn-sm btn-success mt-2 mb-2 w-100">Zobacz bilet w swoich rezerwacjach</a>

                                    @* ZMIANA 1: Pasażer może anulować ZATWIERDZONĄ rezerwację *@
                                    <form asp-controller="Booking" asp-action="Cancel" method="post" onsubmit="return confirm('Czy na pewno chcesz anulować swoją rezerwację? To zwolni miejsce dla innych.');">
                                        <input type="hidden" name="id" value="@myBooking.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger w-100">Rezygnuję z przejazdu</button>
                                    </form>
                                </div>
                            }
                            else if (myBooking.Status == projekt_zespołowy.Models.BookingStatus.Pending)
                            {
                                <div class="alert alert-warning border-warning text-dark">
                                    <i class="bi bi-hourglass-split fs-1 d-block mb-2"></i>
                                    <h4 class="alert-heading">Oczekiwanie</h4>
                                    <p class="mb-2">Wysłano prośbę do kierowcy. Czekaj na akceptację.</p>

                                    @* ZMIANA 1: Pasażer może anulować OCZEKUJĄCĄ rezerwację *@
                                    <form asp-controller="Booking" asp-action="Cancel" method="post" onsubmit="return confirm('Na pewno wycofać prośbę?');">
                                        <input type="hidden" name="id" value="@myBooking.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-dark w-100">Wycofaj prośbę</button>
                                    </form>
                                </div>
                            }
                            else if (myBooking.Status == projekt_zespołowy.Models.BookingStatus.Rejected)
                            {
                                <div class="alert alert-danger border-danger">
                                    <i class="bi bi-x-circle fs-1 d-block mb-2"></i>
                                    <h4 class="alert-heading">Odrzucono</h4>
                                    <p class="mb-2">Kierowca odrzucił Twoją prośbę.</p>
                                    @if (!string.IsNullOrEmpty(myBooking.CommentByDriver))
                                    {
                                        <div class="bg-white p-2 rounded text-start small border border-danger border-opacity-25">
                                            <strong>Powód:</strong> <span class="fst-italic">@myBooking.CommentByDriver</span>
                                        </div>
                                    }
                                </div>
                            }
                        }
                        else if (seatsAvailable <= 0)
                        {
                            <div class="alert alert-secondary border-0 bg-light">
                                <i class="bi bi-emoji-frown fs-1 d-block mb-2 text-muted"></i>
                                <h4 class="text-muted">Brak miejsc</h4>
                                <p class="mb-0 small">Ten przejazd jest już pełny.</p>
                            </div>
                        }
                        else
                        {
                            <h1 class="display-3 fw-bold text-success">@seatsAvailable</h1>
                            <p class="text-muted mb-4">Wolnych miejsc</p>

                            @if (currentUser != null)
                            {
                                <form asp-controller="Booking" asp-action="Create" method="post">
                                    <input type="hidden" name="rideId" value="@Model.Id" />

                                    <div class="mb-3 text-start">
                                        <label class="form-label small fw-bold">Ile miejsc rezerwujesz?</label>
                                        <select name="seats" class="form-select">
                                            @for (int i = 1; i <= seatsAvailable && i <= 4; i++)
                                            {
                                                <option value="@i">@i osoba@(i > 1 ? "y" : "")</option>
                                            }
                                        </select>
                                    </div>

                                    <div class="mb-3 text-start">
                                        <label class="form-label small fw-bold">Wiadomość do kierowcy (opcjonalnie)</label>
                                        <textarea name="comment" class="form-control form-control-sm" rows="2" placeholder="Napisz np. czy masz duży bagaż..."></textarea>
                                    </div>

                                    <button type="submit" class="btn btn-success w-100 py-2 fw-bold shadow-sm">
                                        Poproś o rezerwację
                                    </button>
                                </form>
                            }
                            else
                            {
                                <div class="d-grid">
                                    <a asp-controller="Account" asp-action="Login" class="btn btn-primary">
                                        Zaloguj się, aby zarezerwować
                                    </a>
                                </div>
                            }
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>
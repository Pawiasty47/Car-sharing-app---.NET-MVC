@model projekt_zespołowy.Models.OfferedRide
@using Microsoft.AspNetCore.Identity
@using projekt_zespołowy.Models

@inject UserManager<User> UserManager
@{
    ViewData["Title"] = "Szczegóły przejazdu";

    var currentUser = await UserManager.GetUserAsync(User);
    var isDriver = currentUser != null && Model.DriverId == currentUser.Id;
    var bookings = ViewBag.Bookings as List<Booking> ?? new List<Booking>();
    var myBooking = currentUser != null ? bookings.FirstOrDefault(b => b.PassengerUserId == currentUser.Id) : null;
    var isBooked = myBooking != null;
    var seatsAvailable = Model.SeatsOffered - Model.SeatsTaken;
    var hasBookings = bookings.Any();

    // DODANE: słownik ocen pasażerów przekazany przez kontroler
    var passengerRatings = ViewBag.PassengerRatings as System.Collections.Generic.Dictionary<Guid, double> ?? new System.Collections.Generic.Dictionary<Guid, double>();
}

<div class="container mt-4">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0"><i class="bi bi-info-circle me-2"></i>Szczegóły Przejazdu</h4>
                    <span class="badge bg-white text-primary fs-6">
                        @Model.PricePerSeat.ToString("C") / os.
                    </span>
                </div>
                <div class="card-body">
                    <div class="row text-center align-items-center mb-4">
                        <div class="col-5">
                            <h3 class="fw-bold text-primary">@Model.StartLocation.City</h3>
                            <p class="text-muted mb-0">@Model.StartLocation.Address</p>
                            <span class="badge bg-light text-dark border">
                                @Model.DepartureTime.ToString("dd.MM.yyyy HH:mm")
                            </span>
                        </div>
                        <div class="col-2">
                            <i class="bi bi-arrow-right fs-1 text-muted"></i>
                        </div>
                        <div class="col-5">
                            <h3 class="fw-bold text-primary">@Model.EndLocation.City</h3>
                            <p class="text-muted mb-0">@Model.EndLocation.Address</p>
                            @if (Model.ArrivalTime.HasValue)
                            {
                                <span class="badge bg-light text-dark border">
                                    @Model.ArrivalTime.Value.ToString("dd.MM.yyyy HH:mm")
                                </span>
                            }
                        </div>
                    </div>
                    <hr />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="d-flex align-items-center p-3 bg-light rounded h-100">
                                <div class="fs-1 me-3">👤</div>
                                <div>
                                    <small class="text-muted text-uppercase fw-bold">Kierowca</small>
                                    <h5 class="mb-0">@Model.Driver?.User?.FirstName @Model.Driver?.User?.LastName</h5>
                                    <small class="text-warning">★ @Model.Driver?.Rating / 5.0</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="d-flex align-items-center p-3 bg-light rounded h-100">
                                <div class="fs-1 me-3">🚗</div>
                                <div>
                                    <small class="text-muted text-uppercase fw-bold">Pojazd</small>
                                    <h5 class="mb-0">@Model.Vehicle?.Make @Model.Vehicle?.Model</h5>
                                    <small class="text-muted">@Model.Vehicle?.Color</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Notes))
                    {
                        <div class="mt-4">
                            <h6 class="fw-bold"><i class="bi bi-chat-quote me-2"></i>Uwagi:</h6>
                            <p class="fst-italic text-muted">"@Model.Notes"</p>
                        </div>
                    }
                </div>
            </div>

            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Wróć do listy
            </a>
        </div>

        <div class="col-lg-4">

            @if (isDriver)
            {
                <div class="card border-success shadow-sm">
                    <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-people-fill me-2"></i>Lista Pasażerów</h5>
                        <div>
                            @if (!hasBookings)
                            {
                                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-light me-1" title="Edytuj przejazd">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-light" title="Usuń przejazd">
                                    <i class="bi bi-trash"></i>
                                </a>
                            }
                            else
                            {
                                <button type="button" class="btn btn-sm btn-outline-light me-1" disabled title="Zablokowane — są już zapisani pasażerowie">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-light" disabled title="Zablokowane — są już zapisani pasażerowie">
                                    <i class="bi bi-trash"></i>
                                </button>
                            }

                            @* Przyciski zakończenia / podsumowania przejazdu dla kierowcy *@
                            @if (Model.Status != RideStatus.Completed)
                            {
                                <form asp-action="Complete" method="post" class="d-inline ms-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-light" onclick="return confirm('Zakończyć przejazd?')"
                                            title="Zakończ przejazd">
                                        <i class="bi bi-check2-circle"></i>
                                    </button>
                                </form>
                            }
                            else
                            {
                                <a asp-action="Summary" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-light ms-2" title="Podsumowanie przejazdu">
                                    <i class="bi bi-file-earmark-text"></i>
                                </a>
                            }
                        </div>
                    </div>
                    <div class="card-body p-0">
                        @if (bookings.Any())
                        {
                            <div class="list-group list-group-flush">
                                @foreach (var b in bookings)
                                {
                                    <div class="list-group-item">
                                        <div class="row align-items-center g-3">
                                            <div class="col-auto">
                                                <span class="badge bg-primary text-white rounded-pill">
                                                    @b.SeatsRequested
                                                </span>
                                            </div>
                                            <div class="col">
                                                <div class="d-flex justify-content-between align-items-center">
                                                    <h6 class="mb-0">
                                                        @b.Passenger?.FirstName @b.Passenger?.LastName
                                                        @* DODANE: pokazanie oceny pasażera obok imienia (jeśli jest dostępna) *@
                                                        <small class="text-warning ms-2">
                                                            @(
                                                                passengerRatings.ContainsKey(b.PassengerUserId)
                                                                ? $"★ {passengerRatings[b.PassengerUserId].ToString("0.0")}/5"
                                                                : "—"
                                                            )
                                                        </small>
                                                    </h6>
                                                    <small class="text-muted">
                                                        @b.CreatedAt.ToString("dd.MM.yyyy")
                                                    </small>
                                                </div>
                                                @if (!string.IsNullOrEmpty(b.CommentByPassenger))
                                                {
                                                    <p class="mb-0 fst-italic text-muted">
                                                        "@b.CommentByPassenger"
                                                    </p>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="p-3 text-center text-muted">
                                Brak pasażerów jeszcze
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="card shadow-sm sticky-top" style="top: 20px; z-index: 1;">
                    <div class="card-body text-center">
                        <h5 class="text-uppercase text-muted small fw-bold mb-3">Dostępność miejsc</h5>

                        @if (isBooked)
                        {
                            <div class="alert alert-success border-success">
                                <i class="bi bi-ticket-perforated-fill fs-1 d-block mb-2"></i>
                                <h4 class="alert-heading">Rezerwacja potwierdzona!</h4>
                                <p class="mb-0">Twoje miejsce jest zarezerwowane.</p>
                                <a asp-controller="Booking" asp-action="Index" class="btn btn-sm btn-success mt-2">Zobacz rezerwacje</a>
                            </div>
                        }
                        else if (seatsAvailable <= 0)
                        {
                            <div class="alert alert-secondary border-0 bg-light">
                                <i class="bi bi-emoji-frown fs-1 d-block mb-2 text-muted"></i>
                                <h4 class="text-muted">Brak miejsc</h4>
                                <p class="mb-0 small">Ten przejazd jest już pełny.</p>
                            </div>
                        }
                        else
                        {
                            <h1 class="display-3 fw-bold text-success">@seatsAvailable</h1>
                            <p class="text-muted mb-4">Wolnych miejsc</p>

                            @if (currentUser != null)
                            {
                                <form asp-controller="Booking" asp-action="Create" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="rideId" value="@Model.Id" />

                                    <div class="mb-3 text-start">
                                        <label class="form-label small fw-bold">Ile miejsc rezerwujesz?</label>
                                        <select name="seats" class="form-select">
                                            @for (int i = 1; i <= seatsAvailable && i <= 4; i++)
                                            {
                                                <option value="@i">@i @((i == 1) ? "osoba" : (i >= 2 && i <= 4) ? "osoby" : "osób")</option>
                                            }
                                        </select>
                                    </div>

                                    <div class="mb-3 text-start">
                                        <label class="form-label small fw-bold">Wiadomość do kierowcy (opcjonalnie)</label>
                                        <textarea name="comment" class="form-control form-control-sm" rows="2" placeholder="Napisz np. czy masz duży bagaż..."></textarea>
                                    </div>

                                    <button type="submit" class="btn btn-success w-100 py-2 fw-bold shadow-sm">
                                        Rezerwuję miejsce
                                    </button>
                                </form>
                            }
                            else
                            {
                                <div class="alert alert-warning">
                                    <i class="bi bi-info-circle me-2"></i>
                                    Zaloguj się, aby móc dokonać rezerwacji.
                                </div>

                                <a asp-controller="Account" asp-action="Login" class="btn btn-primary w-100 mt-2">
                                    <i class="bi bi-box-arrow-in-right me-2"></i> Zaloguj się
                                </a>
                            }
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>
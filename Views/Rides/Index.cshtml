@model IEnumerable<projekt_zespołowy.Models.OfferedRide>
@using Microsoft.AspNetCore.Identity
@using projekt_zespołowy.Models

@inject UserManager<User> UserManager

@{
    ViewData["Title"] = "Dostępne przejazdy";
    var currentUserId = UserManager.GetUserId(User);
}

<div class="container mt-4">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> <strong>Sukces!</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> <strong>Uwaga!</strong> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary">
                <i class="bi bi-map-fill me-2"></i>Dostępne przejazdy
            </h2>
            <p class="text-muted">Przeglądaj oferty przejazdów z bazy danych.</p>
        </div>

        <div class="d-flex gap-2">
            <a asp-action="Archival" class="btn btn-outline-secondary btn-lg shadow-sm">
                <i class="bi bi-archive me-2"></i>Archiwum
            </a>
            <a asp-action="Create" class="btn btn-success btn-lg shadow-sm">
                <i class="bi bi-plus-circle me-2"></i>Dodaj nowy
            </a>
        </div>
    </div>

    <div class="card bg-light border-0 shadow-sm mb-5">
        <div class="card-body p-4">
            <form asp-action="Index" method="get">
                <div class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label fw-bold small text-uppercase text-muted">Skąd</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white"><i class="bi bi-geo-alt"></i></span>
                            <input type="text" name="searchFrom" class="form-control"
                                   placeholder="Miasto startu..." value="@ViewData["CurrentFilterFrom"]" />
                        </div>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold small text-uppercase text-muted">Dokąd</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white"><i class="bi bi-geo-alt-fill"></i></span>
                            <input type="text" name="searchTo" class="form-control"
                                   placeholder="Miasto docelowe..." value="@ViewData["CurrentFilterTo"]" />
                        </div>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold small text-uppercase text-muted">Data</label>
                        <input type="date" name="searchDate" class="form-control"
                               value="@ViewData["CurrentFilterDate"]" />
                    </div>

                    <div class="col-md-3">
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-search me-2"></i>Szukaj
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                                Wyczyść filtry
                            </a>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-warning text-center p-5 rounded-3 shadow-sm" role="alert">
            <h4 class="alert-heading"><i class="bi bi-emoji-frown me-2"></i>Brak tras</h4>
            @if (ViewData["CurrentFilterFrom"] != null || ViewData["CurrentFilterTo"] != null || ViewData["CurrentFilterDate"] != null)
            {
                <p>Niestety, nie znaleziono przejazdów spełniających Twoje kryteria wyszukiwania.</p>
                <a asp-action="Index" class="btn btn-outline-dark mt-2">Pokaż wszystkie trasy</a>
            }
            else
            {
                <p>W bazie danych nie ma jeszcze żadnych przejazdów.</p>
                <hr>
                <p class="mb-0">Kliknij przycisk <strong>Dodaj nowy przejazd</strong>, aby stworzyć pierwszy rekord.</p>
            }
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                var seatsAvailable = item.SeatsOffered - item.SeatsTaken;
                var isFull = seatsAvailable <= 0;
                var isOwner = currentUserId != null && item.DriverId.ToString() == currentUserId;
                var isAdmin = User.IsInRole("Admin");
                var canEditOrDelete = (isOwner || isAdmin) && item.SeatsTaken == 0;

                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0 hover-effect">
                        <div class="card-header bg-white border-bottom-0 pt-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="badge bg-primary rounded-pill">
                                    <i class="bi bi-calendar-event me-1"></i>
                                    @item.DepartureTime.ToString("dd.MM.yyyy")
                                </span>
                                <span class="fw-bold text-success fs-5 d-flex align-items-center">
                                    @item.PricePerSeat.ToString("C")
                                    @if (item.IsFlexiblePrice)
                                    {
                                        <span class="badge bg-warning text-dark ms-2 rounded-pill" style="font-size: 0.5em; text-transform: uppercase;">Do negocjacji</span>
                                    }
                                </span>
                            </div>
                        </div>

                        <div class="card-body">
                            <div class="d-flex align-items-center mb-3">
                                <div class="text-center me-3">
                                    <div class="fw-bold fs-5">@item.DepartureTime.ToString("HH:mm")</div>
                                    <small class="text-muted">Wyjazd</small>
                                </div>
                                <div class="flex-grow-1 border-top border-2 border-secondary position-relative text-center" style="height: 0;">
                                    <i class="bi bi-arrow-right-circle-fill position-absolute top-0 start-50 translate-middle bg-white text-secondary" style="margin-top: -1px;"></i>
                                </div>
                                <div class="text-center ms-3">
                                    @if (item.ArrivalTime.HasValue)
                                    {
                                        <div class="fw-bold fs-5">@item.ArrivalTime.Value.ToString("HH:mm")</div>
                                    }
                                    else
                                    {
                                        <div class="fw-bold fs-5">--:--</div>
                                    }
                                    <small class="text-muted">Dojazd</small>
                                </div>
                            </div>

                            <h5 class="card-title text-center fw-bold mb-3">
                                @(item.StartLocation?.City ?? "Nieznane")
                                <i class="bi bi-arrow-right mx-2 text-muted"></i>
                                @(item.EndLocation?.City ?? "Nieznane")
                            </h5>
                            <hr class="text-muted opacity-25">
                            <p class="card-text small text-muted mb-2">
                                <i class="bi bi-car-front-fill me-2 text-primary"></i>
                                <strong>Pojazd:</strong> @(item.Vehicle?.Make ?? "Brak") @(item.Vehicle?.Model)
                            </p>
                            <p class="card-text small text-muted">
                                <i class="bi bi-people-fill me-2 text-primary"></i>
                                <strong>Miejsca:</strong>
                                @if (isFull)
                                {
                                    <span class="badge bg-danger">BRAK MIEJSC</span>
                                }
                                else
                                {
                                    <span>@seatsAvailable wolnych (z @item.SeatsOffered)</span>
                                }
                            </p>
                        </div>

                        <div class="card-footer bg-light border-top-0 pb-3 pt-0">
                            <div class="d-grid gap-2 d-flex justify-content-end mt-2">

                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-info-circle"></i> Szczegóły
                                </a>

                                @* Pokazuj "Podsumowanie" tylko dla zakończonych przejazdów *@
                                @if ((isOwner || isAdmin) && item.Status == RideStatus.Completed)
                                {
                                    <a asp-action="Summary" asp-route-id="@item.Id" class="btn btn-outline-info btn-sm ms-1">
                                        <i class="bi bi-file-earmark-text"></i> Podsumowanie
                                    </a>
                                }

                                @if (canEditOrDelete)
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm ms-1">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm ms-1">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                }
                                else if (isOwner || isAdmin)
                                {
                                    <button type="button" class="btn btn-outline-secondary btn-sm ms-1" disabled title="Zablokowane — są już zapisani pasażerowie">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button type="button" class="btn btn-outline-danger btn-sm ms-1" disabled title="Zablokowane — są już zapisani pasażerowie">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .hover-effect {
        transition: transform 0.2s ease-in-out;
    }

        .hover-effect:hover {
            transform: translateY(-5px);
        }
</style>
@model projekt_zespołowy.Models.OfferedRide
@using projekt_zespołowy.Models
@inject Microsoft.AspNetCore.Identity.UserManager<User> UserManager

@{
    ViewData["Title"] = "Podsumowanie przejazdu";
    var bookings = ViewBag.Bookings as List<Booking> ?? new List<Booking>();
    var myReviews = ViewBag.MyReviews as System.Collections.Generic.Dictionary<Guid, Review> ?? new System.Collections.Generic.Dictionary<Guid, Review>();
    var currentUser = await UserManager.GetUserAsync(User);
    var isDriver = currentUser != null && Model.DriverId == currentUser.Id;
    var isPassenger = currentUser != null && bookings.Any(b => b.PassengerUserId == currentUser.Id);
}

<div class="container mt-4">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Podsumowanie przejazdu</h4>
            @if (Model.Status == RideStatus.Completed)
            {
                <span class="badge bg-success">Zakończony</span>
            }
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <p><strong>Trasa:</strong> @Model.StartLocation.City ? @Model.EndLocation.City</p>
                    <p><strong>Data:</strong> @Model.DepartureTime.ToString("dd.MM.yyyy HH:mm")</p>
                </div>
                <div class="col-md-6 text-end">
                    <p><strong>Pojazd:</strong> @Model.Vehicle?.Make @Model.Vehicle?.Model</p>
                </div>
            </div>

            <hr />

            <h5>Kierowca</h5>
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <strong>@Model.Driver?.User?.FirstName @Model.Driver?.User?.LastName</strong>
                    <div class="small text-muted">@Model.Driver?.User?.Email</div>
                    <div class="small text-warning">
                        <i class="bi bi-star-fill text-warning"></i>
                        @Model.Driver?.Rating / 5.0
                    </div>
                </div>

                <div class="text-end" style="min-width:300px;">
                    @if (isPassenger && Model.Status == RideStatus.Completed)
                    {
                        if (myReviews.ContainsKey(Model.DriverId))
                        {
                            <div class="text-success small">
                                Oceniłeś kierowcę:
                                <i class="bi bi-star-fill text-warning"></i>
                                <strong>@myReviews[Model.DriverId].Rating</strong>
                                @if (!string.IsNullOrWhiteSpace(myReviews[Model.DriverId].Comment))
                                {
                                    <div class="fst-italic small text-muted">@myReviews[Model.DriverId].Comment</div>
                                }
                            </div>
                        }
                        else
                        {
                            <form asp-action="RateDriver" method="post" class="text-end">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="rideId" value="@Model.Id" />
                                <div class="d-flex gap-2 align-items-center">
                                    <select name="rating" class="form-select form-select-sm" style="width:90px;">
                                        <option value="5">5</option>
                                        <option value="4">4</option>
                                        <option value="3">3</option>
                                        <option value="2">2</option>
                                        <option value="1">1</option>
                                    </select>
                                    <input name="comment" class="form-control form-control-sm" placeholder="Opcjonalny komentarz" />
                                    <button type="submit" class="btn btn-sm btn-primary">Oceń kierowcę</button>
                                </div>
                            </form>
                        }
                    }
                    else if (!isPassenger)
                    {
                        <small class="text-muted">Tylko zapisani pasażerowie mogą ocenić kierowcę.</small>
                    }
                    else
                    {
                        <small class="text-muted">Oceny dostępne po zakończeniu przejazdu</small>
                    }
                </div>
            </div>

            <hr />

            <h5>Pasażerowie (@bookings.Count)</h5>

            @if (!bookings.Any())
            {
                <div class="text-muted">Brak zapisanych pasażerów.</div>
            }
            else
            {
                <div class="list-group">
                    @foreach (var b in bookings)
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-start">
                            <div>
                                <strong>@b.Passenger?.FirstName @b.Passenger?.LastName</strong>
                                <div class="small text-muted">@b.Passenger?.Email</div>
                            </div>

                            <div class="text-end" style="min-width:300px;">
                                @if (isDriver && Model.Status == RideStatus.Completed)
                                {
                                    if (myReviews.ContainsKey(b.PassengerUserId))
                                    {
                                        <div class="text-success small">
                                            Oceniłeś:
                                            <i class="bi bi-star-fill text-warning"></i>
                                            <strong>@myReviews[b.PassengerUserId].Rating</strong>
                                            @if (!string.IsNullOrWhiteSpace(myReviews[b.PassengerUserId].Comment))
                                            {
                                                <div class="fst-italic small text-muted">@myReviews[b.PassengerUserId].Comment</div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <form asp-action="RatePassenger" method="post" class="text-end">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="rideId" value="@Model.Id" />
                                            <input type="hidden" name="passengerUserId" value="@b.PassengerUserId" />
                                            <div class="d-flex gap-2 align-items-center">
                                                <select name="rating" class="form-select form-select-sm" style="width:90px;">
                                                    <option value="5">5</option>
                                                    <option value="4">4</option>
                                                    <option value="3">3</option>
                                                    <option value="2">2</option>
                                                    <option value="1">1</option>
                                                </select>
                                                <input name="comment" class="form-control form-control-sm" placeholder="Opcjonalny komentarz" />
                                                <button type="submit" class="btn btn-sm btn-primary">Oceń</button>
                                            </div>
                                        </form>
                                    }
                                }
                                else
                                {
                                    <small class="text-muted">Oceny dostępne po zakończeniu przejazdu</small>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <a asp-action="Index" asp-controller="Rides" class="btn btn-outline-secondary">Wróć do listy</a>
</div>
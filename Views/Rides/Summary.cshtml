@model projekt_zespołowy.Models.OfferedRide
@using projekt_zespołowy.Models
@inject Microsoft.AspNetCore.Identity.UserManager<User> UserManager

@{
    ViewData["Title"] = "Podsumowanie przejazdu";
    var bookings = ViewBag.Bookings as List<Booking> ?? new List<Booking>();
    var myReviews = ViewBag.MyReviews as System.Collections.Generic.Dictionary<Guid, Review> ?? new System.Collections.Generic.Dictionary<Guid, Review>();
    var currentUser = await UserManager.GetUserAsync(User);
    var isDriver = currentUser != null && Model.DriverId == currentUser.Id;
    var isPassenger = currentUser != null && bookings.Any(b => b.PassengerUserId == currentUser.Id);
}

<div class="container mt-4">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    @if (Model.Status == RideStatus.Cancelled)
    {
        <div class="alert alert-danger shadow-sm border-danger border-2 text-center p-4 mb-4">
            <i class="bi bi-x-octagon-fill fs-1 d-block mb-2"></i>
            <h4 class="alert-heading fw-bold">Przejazd odwołany!</h4>
            <p class="mb-0">Ten przejazd został odwołany przez kierowcę i nie doszedł do skutku.</p>
        </div>
    }

    <div class="card shadow-sm mb-4 @(Model.Status == RideStatus.Cancelled ? "opacity-75" : "")">
        <div class="card-header @(Model.Status == RideStatus.Cancelled ? "bg-danger" : "bg-primary") text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Podsumowanie przejazdu</h4>
            @if (Model.Status == RideStatus.Completed)
            {
                <span class="badge bg-success">Zakończony</span>
            }
            else if (Model.Status == RideStatus.Cancelled)
            {
                <span class="badge bg-dark">Odwołany</span>
            }
        </div>
        <div class="card-body">
            <div class="row mb-4 text-center">
                <div class="col-5">
                    <h4 class="fw-bold">@Model.StartLocation?.City</h4>
                    <p class="text-muted mb-0">@Model.StartLocation?.Address</p>
                </div>
                <div class="col-2">
                    <i class="bi bi-arrow-right fs-2"></i>
                </div>
                <div class="col-5">
                    <h4 class="fw-bold">@Model.EndLocation?.City</h4>
                    <p class="text-muted mb-0">@Model.EndLocation?.Address</p>
                </div>
            </div>
            <div class="text-center mb-4">
                <span class="badge bg-light text-dark border">Wyjazd: @Model.DepartureTime.ToString("dd.MM.yyyy HH:mm")</span>
            </div>

            @if (isPassenger && Model.Status == RideStatus.Completed)
            {
                <div class="alert alert-info border-info mb-4">
                    <h5 class="alert-heading">Oceń kierowcę</h5>
                    @if (myReviews.ContainsKey(Model.DriverId))
                    {
                        <div class="text-success fw-bold">
                            Wystawiłeś już ocenę kierowcy: @myReviews[Model.DriverId].Rating / 5
                        </div>
                    }
                    else
                    {
                        <form asp-action="RateDriver" method="post" class="mt-3">
                            <input type="hidden" name="rideId" value="@Model.Id" />
                            <div class="d-flex gap-2 align-items-center">
                                <label class="fw-bold mb-0">Twoja ocena:</label>
                                <select name="rating" class="form-select form-select-sm" style="width: 100px;">
                                    <option value="5">5 gwiazdek</option>
                                    <option value="4">4 gwiazdki</option>
                                    <option value="3">3 gwiazdki</option>
                                    <option value="2">2 gwiazdki</option>
                                    <option value="1">1 gwiazdka</option>
                                </select>
                                <input type="text" name="comment" class="form-control form-control-sm w-50" placeholder="Krótki komentarz (opcjonalnie)" />
                                <button type="submit" class="btn btn-primary btn-sm">Zapisz opinię</button>
                            </div>
                        </form>
                    }
                </div>
            }

            @if (isDriver || User.IsInRole("Admin"))
            {
                <h5 class="fw-bold border-bottom pb-2">Pasażerowie (@bookings.Count(b => b.Status == BookingStatus.Confirmed || b.Status == BookingStatus.Completed))</h5>
                <div class="list-group">
                    @foreach (var b in bookings.Where(b => b.Status == BookingStatus.Confirmed || b.Status == BookingStatus.Completed))
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <span class="fw-bold">@b.Passenger?.FirstName @b.Passenger?.LastName</span>
                                <span class="badge bg-secondary ms-2">@b.SeatsRequested msc.</span>
                            </div>
                            <div>
                                @if (Model.Status == RideStatus.Completed)
                                {
                                    @if (myReviews.ContainsKey(b.PassengerUserId))
                                    {
                                        <span class="text-success"><i class="bi bi-star-fill"></i> Ocena wystawiona: @myReviews[b.PassengerUserId].Rating</span>
                                    }
                                    else
                                    {
                                        <form asp-action="RatePassenger" method="post" class="m-0">
                                            <input type="hidden" name="rideId" value="@Model.Id" />
                                            <input type="hidden" name="passengerUserId" value="@b.PassengerUserId" />
                                            <div class="input-group input-group-sm">
                                                <select name="rating" class="form-select form-select-sm" style="width:90px;">
                                                    <option value="5">5</option>
                                                    <option value="4">4</option>
                                                    <option value="3">3</option>
                                                    <option value="2">2</option>
                                                    <option value="1">1</option>
                                                </select>
                                                <input name="comment" class="form-control form-control-sm" placeholder="Opcjonalny komentarz" />
                                                <button type="submit" class="btn btn-sm btn-primary">Oceń</button>
                                            </div>
                                        </form>
                                    }
                                }
                                else if (Model.Status == RideStatus.Cancelled)
                                {
                                    <small class="text-muted">Przejazd odwołany (brak możliwości oceniania)</small>
                                }
                                else
                                {
                                    <small class="text-muted">Oceny dostępne po zakończeniu przejazdu</small>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <a asp-action="Index" asp-controller="Rides" class="btn btn-outline-secondary">Wróć do listy</a>
</div>
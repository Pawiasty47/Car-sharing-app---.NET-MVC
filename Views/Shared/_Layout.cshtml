@{
    var title = ViewData["Title"] ?? "Wóz albo Przewóz";
}
<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title - RideshareCity</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet" />

    <!-- Nasze style -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @await RenderSectionAsync("Head", required: false)
</head>
<body>
    <!-- Górny pasek nawigacyjny -->
    <partial name="_Navbar" />

    <!-- Sekcja hero (opcjonalna) -->
    <header class="hero-section text-white text-center py-5 mb-4">
        <div class="container">
            <h1 class="display-5 fw-bold">Podróżuj razem — taniej, wygodniej, ekologiczniej</h1>
            <p class="lead">Znajdź kierowcę lub pasażera w Twoim mieście i dziel się kosztami podróży.</p>
        </div>
    </header>

    <!-- Główna zawartość -->
    <main role="main" class="container mb-5">
        @RenderBody()
    </main>

    <!-- Stopka -->
    <partial name="_Footer" />

    <!-- Skrypty -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>

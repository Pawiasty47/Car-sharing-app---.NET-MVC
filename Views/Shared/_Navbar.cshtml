@inject AppDbContext Db

<nav class="navbar navbar-expand-lg navbar-dark bg-success shadow-sm sticky-top">
    <div class="container">
        <a class="navbar-brand fw-bold d-flex align-items-center" asp-controller="Home" asp-action="Index">
            🚗 Wóz albo Przewóz
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarMain">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Vehicle" asp-action="Index">
                        🚘 Lista pojazdów
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" asp-controller="Rides" asp-action="Index">
                        🔍 Wyszukaj przejazd
                    </a>
                </li>

                @if (User.Identity?.IsAuthenticated ?? false)
                {
                    if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item ms-3">
                            <a class="nav-link" asp-controller="Admin" asp-action="Users">
                                🛠️ Panel Administratora
                            </a>
                        </li>
                    }
                }
            </ul>

            <ul class="navbar-nav ms-auto align-items-center">
                @if (User.Identity?.IsAuthenticated ?? false)
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Chat" asp-action="ChatList">
                            💬 Chaty
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="PassengerProfile" asp-action="Index">
                            👤 Mój Profil
                        </a>
                    </li>

                    <li class="nav-item ms-2">
                        <a class="nav-link" asp-controller="Notifications" asp-action="Index">
                            🔔 Powiadomienia
                        </a>
                    </li>

                    <li class="nav-item ms-2">
                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                            <button type="submit" class="nav-link bg-transparent border-0">
                                🚪 Wyloguj
                            </button>
                        </form>
                    </li>
                }
                else
                {
                    <partial name="_LoginPartial" />
                }
            </ul>
        </div>
    </div>
</nav>
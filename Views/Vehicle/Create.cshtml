@model projekt_zespołowy.Models.ViewModels.AddVehicleViewModel
@{
    ViewData["Title"] = "Dodaj pojazd";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h3 class="fw-bold text-success text-center mb-4">Dodaj pojazd</h3>
                <!-- WAŻNE: enctype -->
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    @if (User.IsInRole("Admin"))
                    {
                        <div class="mb-3">
                            <label asp-for="OwnerId" class="form-label text-muted small fw-bold">ID Właściciela (Admin)</label>
                            <input asp-for="OwnerId" class="form-control form-control-sm font-monospace" />
                        </div>
                    }

                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label asp-for="Make" class="form-label fw-bold">Marka</label>
                            <input asp-for="Make" class="form-control" />
                            <span asp-validation-for="Make" class="text-danger small"></span>
                        </div>
                        <div class="col-6">
                            <label asp-for="Model" class="form-label fw-bold">Model</label>
                            <input asp-for="Model" class="form-control" />
                            <span asp-validation-for="Model" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="RegistrationNumber" class="form-label fw-bold">Rejestracja</label>
                        <input asp-for="RegistrationNumber" class="form-control text-uppercase" />
                        <span asp-validation-for="RegistrationNumber" class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label asp-for="Color" class="form-label fw-bold">Kolor</label>
                            <input asp-for="Color" class="form-control" />
                        </div>
                        <div class="col-6">
                            <label asp-for="SeatsTotal" class="form-label fw-bold">Miejsca</label>
                            <input asp-for="SeatsTotal" type="number" class="form-control" min="2" max="9" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="VehiclePhoto" class="form-label fw-bold">Zdjęcie</label>
                        <input asp-for="VehiclePhoto" class="form-control" type="file" accept="image/*" />
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-success">Zapisz</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Anuluj</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
 }
@model IEnumerable<projekt_zespołowy.Models.Vehicle>

@{
    ViewData["Title"] = "Lista pojazdów";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-success">
            <i class="bi bi-car-front"></i> Lista pojazdów
        </h2>

        <div>
            <a asp-action="Create" class="btn btn-success me-2">
                <i class="bi bi-plus-lg"></i> Dodaj pojazd
            </a>

            <a asp-action="MyVehicles" class="btn btn-primary">
                <i class="bi bi-person-circle"></i> Moje samochody
            </a>
        </div>
    </div>


    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">
            <i class="bi bi-info-circle me-2"></i>
            Nie dodano jeszcze żadnych pojazdów.
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var v in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body">

                            <h5 class="card-title fw-bold mb-2">
                                @v.Make @v.Model
                            </h5>

                            <p class="text-muted mb-1">
                                <i class="bi bi-postcard me-1"></i>
                                <strong>Rejestracja:</strong> @v.RegistrationNumber
                            </p>

                            <p class="text-muted mb-1">
                                <i class="bi bi-palette me-1"></i>
                                <strong>Kolor:</strong> @v.Color
                            </p>

                            <p class="text-muted mb-3">
                                <i class="bi bi-people me-1"></i>
                                <strong>Miejsca:</strong> @v.SeatsAvailable / @v.SeatsTotal
                            </p>

                            <div class="d-flex justify-content-between">
                                <a asp-action="Details" asp-route-id="@v.Id" class="btn btn-outline-success btn-sm">
                                    <i class="bi bi-eye"></i> Szczegóły
                                </a>
                                <a asp-action="Edit" asp-route-id="@v.Id" class="btn btn-outline-warning btn-sm">
                                    <i class="bi bi-pencil-square"></i> Edytuj
                                </a>
                                <a asp-action="Delete" asp-route-id="@v.Id" class="btn btn-outline-danger btn-sm">
                                    <i class="bi bi-trash"></i> Usuń
                                </a>
                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.js"></script>
}

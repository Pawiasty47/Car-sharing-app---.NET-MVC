@model IEnumerable<projekt_zespołowy.Models.Vehicle>
@using Microsoft.AspNetCore.Identity
@using projekt_zespołowy.Models
@inject UserManager<User> UserManager

@{
    ViewData["Title"] = "Lista pojazdów";

    bool isMyVehiclesMode = ViewBag.IsMyVehiclesMode as bool? ?? false;


    bool isAdmin = User.IsInRole("Admin");
}

<div class="container mt-4">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> <strong>Sukces!</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> <strong>Błąd!</strong> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-success">
            <i class="bi bi-car-front"></i>
            @(isMyVehiclesMode ? "Moje samochody" : "Lista wszystkich pojazdów")
        </h2>

        <div>
            <a asp-action="Create" class="btn btn-success me-2">
                <i class="bi bi-plus-lg"></i> Dodaj pojazd
            </a>

            @if (!isMyVehiclesMode)
            {
                <a asp-action="MyVehicles" class="btn btn-primary">
                    <i class="bi bi-person-circle"></i> Moje samochody
                </a>
            }
            else
            {
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Wróć do wszystkich
                </a>
            }
        </div>
    </div>


    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">
            <i class="bi bi-info-circle me-2"></i>
            Nie znaleziono żadnych pojazdów.
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var v in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card shadow-sm border-0 h-100">

                        <!-- Miniaturka zdjęcia (jeśli jest) -->
                        @if (!string.IsNullOrEmpty(v.ImageUrl))
                        {
                            <img src="~/images/vehicles/@v.ImageUrl" class="card-img-top" alt="@v.Make" style="height: 200px; object-fit: cover;">
                        }
                        else
                        {
                            <div class="bg-light text-center py-4 border-bottom text-muted">
                                <i class="bi bi-car-front display-4 opacity-50"></i>
                            </div>
                        }

                        <div class="card-body d-flex flex-column">

                            <h5 class="card-title fw-bold mb-2">
                                @v.Make @v.Model
                            </h5>

                            <p class="text-muted mb-1">
                                <i class="bi bi-postcard me-1"></i>
                                <strong>Rejestracja:</strong> @v.RegistrationNumber
                            </p>

                            <p class="text-muted mb-1">
                                <i class="bi bi-palette me-1"></i>
                                <strong>Kolor:</strong> @v.Color
                            </p>

                            <p class="text-muted mb-3">
                                <i class="bi bi-people me-1"></i>
                                <strong>Miejsca:</strong> @v.SeatsAvailable / @v.SeatsTotal
                            </p>

                            <div class="mt-auto d-flex justify-content-between">
                                <a asp-action="Details" asp-route-id="@v.Id" class="btn btn-outline-success btn-sm">
                                    <i class="bi bi-eye"></i> Szczegóły
                                </a>

                                @if (isMyVehiclesMode || isAdmin)
                                {
                                    <div class="btn-group">
                                        <a asp-action="Edit" asp-route-id="@v.Id" class="btn btn-outline-warning btn-sm">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@v.Id" class="btn btn-outline-danger btn-sm">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                }
                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
}